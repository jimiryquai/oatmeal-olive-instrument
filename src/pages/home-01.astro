---
import Base from '../layouts/Base.astro'
import AnnouncementBadge from '../components/elements/announcement-badge.astro'
import ButtonLink from '../components/elements/ButtonLink.astro'
import PlainButtonLink from '../components/elements/PlainButtonLink.astro'
import SoftButtonLink from '../components/elements/SoftButtonLink.astro'
import Link from '../components/elements/link.astro'
import LogoGrid from '../components/elements/logo-grid.astro'
import Logo from '../components/elements/logo.astro'
import Main from '../components/elements/main.astro'
import Screenshot from '../components/elements/screenshot.astro'
import ArrowNarrowRightIcon from '../components/icons/arrow-narrow-right-icon.astro'
import ChevronIcon from '../components/icons/chevron-icon.astro'
import GitHubIcon from '../components/icons/social/github-icon.astro'
import XIcon from '../components/icons/social/x-icon.astro'
import YouTubeIcon from '../components/icons/social/youtube-icon.astro'
import CallToActionSimple from '../components/sections/CallToActionSimple.astro'
import FAQsTwoColumnAccordion from '../components/sections/FAQsTwoColumnAccordion.astro'
import Faq from '../components/sections/Faq.astro'
import Feature from '../components/sections/Feature.astro'
import FeaturesTwoColumnWithDemos from '../components/sections/FeaturesTwoColumnWithDemos.astro'
import FooterCategory from '../components/sections/FooterCategory.astro'
import FooterLink from '../components/sections/FooterLink.astro'
import FooterWithNewsletterFormCategoriesAndSocialIcons from '../components/sections/FooterWithNewsletterFormCategoriesAndSocialIcons.astro'
import NewsletterForm from '../components/sections/NewsletterForm.astro'
import SocialLink from '../components/sections/SocialLink.astro'
import HeroLeftAlignedWithDemo from '../components/sections/HeroLeftAlignedWithDemo.astro'
import NavbarLink from '../components/sections/NavbarLink.astro'
import NavbarLogo from '../components/sections/NavbarLogo.astro'
import NavbarWithLinksActionsAndCenteredLogo from '../components/sections/NavbarWithLinksActionsAndCenteredLogo.astro'
import Plan from '../components/sections/PricingPlan.astro'
import PricingMultiTier from '../components/sections/PricingMultiTier.astro'
import Stat from '../components/sections/Stat.astro'
import StatsWithGraph from '../components/sections/StatsWithGraph.astro'
import Testimonial from '../components/sections/Testimonial.astro'
import TestimonialThreeColumnGrid from '../components/sections/TestimonialThreeColumnGrid.astro'
---

<Base hideHeaderFooter={true} title="Customer support that feels like a conversation" description="Simplify your shared inbox, collaborate effortlessly, and give every customer a reply that feels personal.">
  <NavbarWithLinksActionsAndCenteredLogo id="navbar">
    <Fragment slot="links">
      <NavbarLink href="#">Pricing</NavbarLink>
      <NavbarLink href="#">About</NavbarLink>
      <NavbarLink href="#">Docs</NavbarLink>
      <NavbarLink href="/_emdash/admin" class="sm:hidden">Log in</NavbarLink>
    </Fragment>
    <NavbarLogo slot="logo" href="#">
      <img
        src="/img/logos/oatmeal-instrument-color-olive-950.svg"
        alt="Oatmeal"
        class="dark:hidden"
        width={85}
        height={28}
      />
      <img
        src="/img/logos/oatmeal-instrument-color-white.svg"
        alt="Oatmeal"
        class="not-dark:hidden"
        width={85}
        height={28}
      />
    </NavbarLogo>
    <Fragment slot="actions">
      <PlainButtonLink href="/_emdash/admin" class="max-sm:hidden">Log in</PlainButtonLink>
      <ButtonLink href="#">Get started</ButtonLink>
    </Fragment>
  </NavbarWithLinksActionsAndCenteredLogo>

  <Main>
    <!-- Hero -->
    <HeroLeftAlignedWithDemo id="hero">
      <AnnouncementBadge slot="eyebrow" href="#" text="Oatmeal raises 80M Series A funding" cta="Learn more" />
      <Fragment slot="headline">Customer support that feels like a conversation.</Fragment>
      <p slot="subheadline">
        Simplify your shared inbox, collaborate effortlessly, and give every customer a reply that feels personal
        — even if it was generated by a bot.
      </p>
      <div slot="cta" class="flex items-center gap-4">
        <ButtonLink href="#" size="lg">
          Start free trial
        </ButtonLink>

        <PlainButtonLink href="#" size="lg">
          See how it works <ArrowNarrowRightIcon />
        </PlainButtonLink>
      </div>

      <Fragment slot="demo">
        <Screenshot class="rounded-md lg:hidden" wallpaper="green" placement="bottom-right">
          <img
            src="/img/screenshots/1-left-1670-top-1408.webp"
            alt=""
            width={1670}
            height={1408}
            class="bg-white/75 md:hidden dark:hidden"
          />
          <img
            src="/img/screenshots/1-color-olive-left-1670-top-1408.webp"
            alt=""
            width={1670}
            height={1408}
            class="bg-black/75 not-dark:hidden md:hidden"
          />
          <img
            src="/img/screenshots/1-left-2000-top-1408.webp"
            alt=""
            width={2000}
            height={1408}
            class="bg-white/75 max-md:hidden dark:hidden"
          />
          <img
            src="/img/screenshots/1-color-olive-left-2000-top-1408.webp"
            alt=""
            width={2000}
            height={1408}
            class="bg-black/75 not-dark:hidden max-md:hidden"
          />
        </Screenshot>
        <Screenshot class="rounded-lg max-lg:hidden" wallpaper="green" placement="bottom">
          <img
            src="/img/screenshots/1.webp"
            alt=""
            class="bg-white/75 dark:hidden"
            width={3440}
            height={1990}
          />
          <img
            class="bg-black/75 not-dark:hidden"
            src="/img/screenshots/1-color-olive.webp"
            alt=""
            width={3440}
            height={1990}
          />
        </Screenshot>
      </Fragment>

      <LogoGrid slot="footer">
        <Logo>
          <img
            src="/img/logos/9-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={51}
            height={32}
          />
          <img
            src="/img/logos/9-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={51}
            height={32}
          />
        </Logo>
        <Logo>
          <img
            src="/img/logos/10-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={70}
            height={32}
          />
          <img
            src="/img/logos/10-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={70}
            height={32}
          />
        </Logo>
        <Logo>
          <img
            src="/img/logos/11-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={100}
            height={32}
          />
          <img
            src="/img/logos/11-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={100}
            height={32}
          />
        </Logo>
        <Logo>
          <img
            src="/img/logos/12-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={85}
            height={32}
          />
          <img
            src="/img/logos/12-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={85}
            height={32}
          />
        </Logo>
        <Logo>
          <img
            src="/img/logos/13-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={75}
            height={32}
          />
          <img
            src="/img/logos/13-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={75}
            height={32}
          />
        </Logo>
        <Logo>
          <img
            src="/img/logos/8-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={85}
            height={32}
          />
          <img
            src="/img/logos/8-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={85}
            height={32}
          />
        </Logo>
      </LogoGrid>
    </HeroLeftAlignedWithDemo>

    <!-- Features -->
    <FeaturesTwoColumnWithDemos
      id="features"
      eyebrow="Powerful features"
      headline="Everything you need to deliver personal, organized, and delightful support."
      subheadline="Work smarter, reply faster, and keep every customer conversation right where it belongs — in one simple inbox."
    >
      <Fragment slot="features">
        <Feature headline="Shared Inbox">
          <Link slot="cta" href="#">
            See how it works <ArrowNarrowRightIcon />
          </Link>
          <p slot="subheadline">
            Keep every customer conversation in one clean, collaborative inbox. A single source of truth is much
            easier to ignore.
          </p>
          <Screenshot slot="demo" wallpaper="purple" placement="bottom-right">
            <img
              src="/img/screenshots/1-left-1000-top-800.webp"
              alt=""
              class="bg-white/75 sm:hidden dark:hidden"
              width={1000}
              height={800}
            />
            <img
              src="/img/screenshots/1-color-olive-left-1000-top-800.webp"
              alt=""
              class="bg-black/75 not-dark:hidden sm:hidden"
              width={1000}
              height={800}
            />
            <img
              src="/img/screenshots/1-left-1800-top-660.webp"
              alt=""
              class="bg-white/75 max-sm:hidden lg:hidden dark:hidden"
              width={1800}
              height={660}
            />
            <img
              src="/img/screenshots/1-color-olive-left-1800-top-660.webp"
              alt=""
              class="bg-black/75 not-dark:hidden max-sm:hidden lg:hidden"
              width={1800}
              height={660}
            />
            <img
              src="/img/screenshots/1-left-1300-top-1300.webp"
              alt=""
              class="bg-white/75 max-lg:hidden xl:hidden dark:hidden"
              width={1300}
              height={1300}
            />
            <img
              src="/img/screenshots/1-color-olive-left-1300-top-1300.webp"
              alt=""
              class="bg-black/75 not-dark:hidden max-lg:hidden xl:hidden"
              width={1300}
              height={1300}
            />
            <img
              src="/img/screenshots/1-left-1800-top-1250.webp"
              alt=""
              class="bg-white/75 max-xl:hidden dark:hidden"
              width={1800}
              height={1250}
            />
            <img
              src="/img/screenshots/1-color-olive-left-1800-top-1250.webp"
              alt=""
              class="bg-black/75 not-dark:hidden max-xl:hidden"
              width={1800}
              height={1250}
            />
          </Screenshot>
        </Feature>
        <Feature headline="Inbox Agent">
          <Link slot="cta" href="#">
            See how it works <ArrowNarrowRightIcon />
          </Link>
          <p slot="subheadline">Get valuable context without having to read through your customer's long, angry email thread.</p>
          <Screenshot slot="demo" wallpaper="blue" placement="bottom-left">
            <img
              src="/img/screenshots/1-right-1000-top-800.webp"
              alt=""
              class="bg-white/75 sm:hidden dark:hidden"
              width={1000}
              height={800}
            />
            <img
              src="/img/screenshots/1-color-olive-right-1000-top-800.webp"
              alt=""
              class="bg-black/75 not-dark:hidden sm:hidden"
              width={1000}
              height={800}
            />
            <img
              src="/img/screenshots/1-right-1800-top-660.webp"
              alt=""
              class="bg-white/75 max-sm:hidden lg:hidden dark:hidden"
              width={1800}
              height={660}
            />
            <img
              src="/img/screenshots/1-color-olive-right-1800-top-660.webp"
              alt=""
              class="bg-black/75 not-dark:hidden max-sm:hidden lg:hidden"
              width={1800}
              height={660}
            />
            <img
              src="/img/screenshots/1-right-1300-top-1300.webp"
              alt=""
              class="bg-white/75 max-lg:hidden xl:hidden dark:hidden"
              width={1300}
              height={1300}
            />
            <img
              src="/img/screenshots/1-color-olive-right-1300-top-1300.webp"
              alt=""
              class="bg-black/75 not-dark:hidden max-lg:hidden xl:hidden"
              width={1300}
              height={1300}
            />
            <img
              src="/img/screenshots/1-right-1800-top-1250.webp"
              alt=""
              class="bg-white/75 max-xl:hidden dark:hidden"
              width={1800}
              height={1250}
            />
            <img
              src="/img/screenshots/1-color-olive-right-1800-top-1250.webp"
              alt=""
              class="bg-black/75 not-dark:hidden max-xl:hidden"
              width={1800}
              height={1250}
            />
          </Screenshot>
        </Feature>
      </Fragment>
    </FeaturesTwoColumnWithDemos>

    <!-- Stats -->
    <StatsWithGraph
      id="stats"
      eyebrow="Built for scale"
      headline="The inbox powering customer conversations everywhere."
      subheadline="Oatmeal helps teams deliver personal, organized, and fast customer support across the world. From small startups to enterprise teams, we process millions of messages each month — using a massive network of low wage workers stationed around the globe."
    >
      <Stat stat="2M+" text="Emails manually processed every week across thousands of teams." />
      <Stat stat="99.98%" text="Uptime — because your customers never stop complaining." />
    </StatsWithGraph>

    <!-- Testimonial -->
    <TestimonialThreeColumnGrid
      id="testimonial"
      headline="What our customers are saying"
      subheadline="We've given these customers a significant discount in exchange for their honest reviews."
    >
      <Testimonial
        name="Jordan Rogers"
        byline="Founder at Anomaly"
      >
        <p slot="quote">
          Oatmeal has completely transformed our customer support operations. To be fair, we weren't doing any
          customer support at all so the bar was pretty low.
        </p>
        <img
          slot="img"
          src="/img/avatars/10-size-160.webp"
          alt=""
          class="not-dark:bg-white/75 dark:bg-black/75"
          width={160}
          height={160}
        />
      </Testimonial>
      <Testimonial
        name="Lynn Marshall"
        byline="Founder at Pine Labs"
      >
        <p slot="quote">
          We use Oatmeal's automation features to make cancellation requests disappear into a black hole,
          improving our retention rates by over 300%.
        </p>
        <img
          slot="img"
          src="/img/avatars/15-size-160.webp"
          alt=""
          class="not-dark:bg-white/75 dark:bg-black/75"
          width={160}
          height={160}
        />
      </Testimonial>
      <Testimonial
        name="Rajat Singh"
        byline="Head of Support at Concise"
      >
        <p slot="quote">
          I've been using the spare time that Oatmeal has freed up to work not just one, but two other jobs, all
          while hitting my core KPIs. My bosses have no idea.
        </p>
        <img
          slot="img"
          src="/img/avatars/13-size-160.webp"
          alt=""
          class="not-dark:bg-white/75 dark:bg-black/75"
          width={160}
          height={160}
        />
      </Testimonial>
      <Testimonial
        name="John Walters"
        byline="CPO at Orbital"
      >
        <p slot="quote">
          Oatmeal has given us key insights into how much our customers absolutely hate using our product and how
          we can improve it to stop them from leaving us.
        </p>
        <img
          slot="img"
          src="/img/avatars/12-size-160.webp"
          alt=""
          class="not-dark:bg-white/75 dark:bg-black/75"
          width={160}
          height={160}
        />
      </Testimonial>
      <Testimonial
        name="Noah Gold"
        byline="CEO at Looply"
      >
        <p slot="quote">
          As a solo founder, Oatmeal has been a lifesaver. It makes it look like Looply is an actual company with
          multiple employees, when in reality it's just me and an AI.
        </p>
        <img
          slot="img"
          src="/img/avatars/11-size-160.webp"
          alt=""
          class="not-dark:bg-white/75 dark:bg-black/75"
          width={160}
          height={160}
        />
      </Testimonial>
      <Testimonial
        name="Mark Levinson"
        byline="COO at Quirk"
      >
        <p slot="quote">
          Thanks to Oatmeal, we've managed to cut our support costs in half by laying off dozens of employees,
          while still improving response times and customer satisfaction.
        </p>
        <img
          slot="img"
          src="/img/avatars/14-size-160.webp"
          alt=""
          class="not-dark:bg-white/75 dark:bg-black/75"
          width={160}
          height={160}
        />
      </Testimonial>
    </TestimonialThreeColumnGrid>

    <!-- FAQs -->
    <FAQsTwoColumnAccordion id="faqs" headline="Questions & Answers">
      <Faq
        id="faq-1"
        question="Do I need a credit card to start the free trial?"
        answer="Yes, but don't worry, you won't be charged until the trial period is over. We won't send you an email reminding you when this happens because we are really hoping you'll forget and we can keep charging you until your cards expires"
      />
      <Faq
        id="faq-2"
        question="Can my whole team use the same inbox?"
        answer="Yes, the more the merrier! Oatmeal works best when your entire company has access. We will charge you per additional seat, but we won't tell you about this until you get your invoice."
      />
      <Faq
        id="faq-3"
        question="Is the AI agent actually a bunch of people in India?"
        answer="Not just India! We have people in lots of countries around the world pretending to be an AI, including some that are currently under sanctions, so we can't legally mention them here."
      />
      <Faq
        id="faq-4"
        question="Does Oatmeal replace my email client?"
        answer="Absolutely. The idea is that we transition you away from email entirely, so you become completely dependent on our service. Like a parasite living off a host."
      />
    </FAQsTwoColumnAccordion>

    <!-- Pricing -->
    <PricingMultiTier
      id="pricing"
      headline="Pricing to fit your business needs."
    >
      <Fragment slot="plans">
        <Plan
          name="Starter"
          price="$12"
          period="/mo"
          features={[
            'Shared inbox for up to 2 mailboxes',
            'Tagging & assignment',
            'Private notes',
            'Automatic replies',
            'Email support',
          ]}
        >
          <p slot="subheadline">Small teams getting started with shared inboxes</p>
          <SoftButtonLink slot="cta" href="#" size="lg">
            Start free trial
          </SoftButtonLink>
        </Plan>
        <Plan
          name="Growth"
          price="$49"
          period="/mo"
          badge="Most popular"
          features={[
            'Everything in Starter',
            'Inbox Agent',
            'Unlimited mailboxes',
            'Collision detection',
            'Snippets and templates',
            'Reporting dashboard',
            'Slack integration',
          ]}
        >
          <p slot="subheadline">Growing teams needing collaboration and insights</p>
          <ButtonLink slot="cta" href="#" size="lg">
            Start free trial
          </ButtonLink>
        </Plan>
        <Plan
          name="Pro"
          price="$299"
          period="/mo"
          features={[
            'Everything in Growth',
            'Custom roles & permissions',
            'Automation engine',
            'API access',
            'SLA tracking',
            'SSO support',
            'SOC 2 compliance',
          ]}
        >
          <p slot="subheadline">Support-focused organizations and larger teams</p>
          <SoftButtonLink slot="cta" href="#" size="lg">
            Start free trial
          </SoftButtonLink>
        </Plan>
      </Fragment>
    </PricingMultiTier>

    <!-- Call To Action -->
    <CallToActionSimple
      id="call-to-action"
      headline="Ready to make customer support feel simple again?"
      subheadline="Join hundreds of teams using Oatmeal to deliver faster, friendlier email support — using a massive network of low wage workers stationed around the globe"
    >
      <div slot="cta" class="flex items-center gap-4">
        <ButtonLink href="#" size="lg">
          Start free trial
        </ButtonLink>

        <PlainButtonLink href="#" size="lg">
          Book a demo <ChevronIcon />
        </PlainButtonLink>
      </div>
    </CallToActionSimple>
  </Main>

  <FooterWithNewsletterFormCategoriesAndSocialIcons id="footer">
    <NewsletterForm
      slot="cta"
      headline="Stay in the loop"
      action="#"
    >
      <p slot="subheadline">
        Get customer support tips, product updates and customer stories that you can archive as soon as they
        arrive.
      </p>
    </NewsletterForm>
    <Fragment slot="links">
      <FooterCategory title="Product">
        <FooterLink href="#">Features</FooterLink>
        <FooterLink href="#">Pricing</FooterLink>
        <FooterLink href="#">Integrations</FooterLink>
      </FooterCategory>
      <FooterCategory title="Company">
        <FooterLink href="#">About</FooterLink>
        <FooterLink href="#">Careers</FooterLink>
        <FooterLink href="#">Blog</FooterLink>
        <FooterLink href="#">Press Kit</FooterLink>
      </FooterCategory>
      <FooterCategory title="Resources">
        <FooterLink href="#">Help Center</FooterLink>
        <FooterLink href="#">API Docs</FooterLink>
        <FooterLink href="#">Status</FooterLink>
        <FooterLink href="#">Contact</FooterLink>
      </FooterCategory>
      <FooterCategory title="Legal">
        <FooterLink href="#">Privacy Policy</FooterLink>
        <FooterLink href="#">Terms of Service</FooterLink>
        <FooterLink href="#">Security</FooterLink>
      </FooterCategory>
    </Fragment>
    <Fragment slot="socialLinks">
      <SocialLink href="https://x.com" name="X">
        <XIcon />
      </SocialLink>
      <SocialLink href="https://github.com" name="GitHub">
        <GitHubIcon />
      </SocialLink>
      <SocialLink href="https://www.youtube.com" name="YouTube">
        <YouTubeIcon />
      </SocialLink>
    </Fragment>
    <span slot="fineprint">© 2025 Oatmeal, Inc.</span>
  </FooterWithNewsletterFormCategoriesAndSocialIcons>
</Base>
