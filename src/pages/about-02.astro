---
import Base from '../layouts/Base.astro'
import AnnouncementBadge from '../components/elements/announcement-badge.astro'
import ButtonLink from '../components/elements/ButtonLink.astro'
import PlainButtonLink from '../components/elements/PlainButtonLink.astro'
import Main from '../components/elements/main.astro'
import ChevronIcon from '../components/icons/chevron-icon.astro'
import GitDiffIcon from '../components/icons/git-diff-icon.astro'
import HeartIcon from '../components/icons/heart-icon.astro'
import RocketIcon from '../components/icons/rocket-icon.astro'
import StarIcon from '../components/icons/star-icon.astro'
import TargetIcon from '../components/icons/target-icon.astro'
import User2Icon from '../components/icons/user-2-icon.astro'
import BrandCard from '../components/sections/BrandCard.astro'
import BrandsCardsMultiColumn from '../components/sections/BrandsCardsMultiColumn.astro'
import CallToActionSimple from '../components/sections/CallToActionSimple.astro'
import Feature from '../components/sections/Feature.astro'
import FeaturesThreeColumn from '../components/sections/FeaturesThreeColumn.astro'
import FooterCategory from '../components/sections/FooterCategory.astro'
import FooterLink from '../components/sections/FooterLink.astro'
import FooterWithLinkCategories from '../components/sections/FooterWithLinkCategories.astro'
import HeroTwoColumnWithPhoto from '../components/sections/HeroTwoColumnWithPhoto.astro'
import NavbarLink from '../components/sections/NavbarLink.astro'
import NavbarLogo from '../components/sections/NavbarLogo.astro'
import NavbarWithLogoActionsAndCenteredLinks from '../components/sections/NavbarWithLogoActionsAndCenteredLinks.astro'
import TeamMember from '../components/sections/TeamMember.astro'
import TeamThreeColumnGrid from '../components/sections/TeamThreeColumnGrid.astro'
---

<Base hideHeaderFooter={true} title="About" description="We're on a mission to take the human element completely out of customer support.">
  <NavbarWithLogoActionsAndCenteredLinks id="navbar">
    <Fragment slot="links">
      <NavbarLink href="#">Pricing</NavbarLink>
      <NavbarLink href="#">About</NavbarLink>
      <NavbarLink href="#">Docs</NavbarLink>
      <NavbarLink href="/_emdash/admin" class="sm:hidden">Log in</NavbarLink>
    </Fragment>
    <NavbarLogo slot="logo" href="#">
      <img
        src="/img/logos/oatmeal-instrument-color-olive-950.svg"
        alt="Oatmeal"
        class="dark:hidden"
        width={85}
        height={28}
      />
      <img
        src="/img/logos/oatmeal-instrument-color-white.svg"
        alt="Oatmeal"
        class="not-dark:hidden"
        width={85}
        height={28}
      />
    </NavbarLogo>
    <Fragment slot="actions">
      <PlainButtonLink href="/_emdash/admin" class="max-sm:hidden">Log in</PlainButtonLink>
      <ButtonLink href="#">Get started</ButtonLink>
    </Fragment>
  </NavbarWithLogoActionsAndCenteredLinks>

  <Main>
    <!-- Hero -->
    <HeroTwoColumnWithPhoto
      id="hero"
      headline="Your customer success is our mission."
    >
      <AnnouncementBadge slot="eyebrow" href="#" text="2025 Business of the Year" cta="Learn more" />
      <p slot="subheadline">
        We're on a mission to take the human element completely out of customer support — so your team can focus
        on what matters most, profitability.
      </p>
      <Fragment slot="photo">
        <img
          class="not-dark:bg-white/75 max-xl:hidden dark:bg-black/75"
          src="/img/photos/1.webp"
          width={1800}
          height={1600}
          alt=""
        />
        <img
          class="not-dark:bg-white/75 xl:hidden dark:bg-black/75"
          src="/img/photos/1.webp"
          width={1800}
          height={945}
          alt=""
        />
      </Fragment>
    </HeroTwoColumnWithPhoto>

    <!-- Brands -->
    <BrandsCardsMultiColumn
      id="brands"
      eyebrow="Backed by the best"
      headline="Funded by leading investors."
    >
      <p slot="subheadline">
        Oatmeal is backed by investors with decades of experience building the world's most boring and predictable
        B2B SaaS.
      </p>
      <BrandCard
        text="Focused capital for founders building the next generation of pyramid shaped businesses."
        footnote="Investor in Anomaly, Concise, Haptic and more."
      >
        <Fragment slot="logo">
          <img
            src="/img/logos/12-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={124}
            height={32}
          />
          <img
            src="/img/logos/12-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={124}
            height={32}
          />
        </Fragment>
      </BrandCard>
      <BrandCard
        text="Serving as a tax-efficiency vehicle for investors waiting to move to a tax haven."
        footnote="Investor in Quirk, Looply, Pine Labs and more."
      >
        <Fragment slot="logo">
          <img
            src="/img/logos/13-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={146}
            height={32}
          />
          <img
            src="/img/logos/13-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={146}
            height={32}
          />
        </Fragment>
      </BrandCard>
      <BrandCard
        text="Investing in potentially volatile bubble markets at an early stage."
        footnote="Investor in Artifact, Umbra, vivid.ai and more."
      >
        <Fragment slot="logo">
          <img
            src="/img/logos/11-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={106}
            height={32}
          />
          <img
            src="/img/logos/11-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={106}
            height={32}
          />
        </Fragment>
      </BrandCard>
    </BrandsCardsMultiColumn>

    <!-- Team -->
    <TeamThreeColumnGrid
      id="team"
      headline="Our leadership team"
    >
      <p slot="subheadline">
        Oatmeals's leadership team combines decades of experience in private equity, where they honed their skills
        in cost-cutting and maximizing shareholder value.
      </p>
      <TeamMember
        name="Leslie Alexander"
        byline="Co-Founder / CEO"
      >
        <img
          slot="img"
          src="/img/avatars/1-h-1000-w-800.webp"
          alt=""
          class="not-dark:bg-white/75 dark:bg-black/75"
          width={800}
          height={800}
        />
      </TeamMember>
      <TeamMember
        name="Michael Foster"
        byline="Co-Founder / CTO"
      >
        <img
          slot="img"
          src="/img/avatars/2-h-1000-w-800.webp"
          alt=""
          class="not-dark:bg-white/75 dark:bg-black/75"
          width={800}
          height={800}
        />
      </TeamMember>
      <TeamMember
        name="Dries Vincent"
        byline="Business Relations"
      >
        <img
          slot="img"
          src="/img/avatars/7-h-1000-w-800.webp"
          alt=""
          class="not-dark:bg-white/75 dark:bg-black/75"
          width={800}
          height={800}
        />
      </TeamMember>
    </TeamThreeColumnGrid>

    <!-- Features -->
    <FeaturesThreeColumn
      id="features"
      headline="Our values."
    >
      <p slot="subheadline">
        Work smarter, reply faster, and keep every customer conversation right where it belongs — in one simple
        inbox, where you can ignore it.
      </p>
      <Fragment slot="features">
        <Feature headline="Innovation">
          <RocketIcon slot="icon" />
          <p slot="subheadline">
            We are constantly pushing the boundaries of what's possible, and legal, in customer support to
            deliver cutting-edge solutions for our clients.
          </p>
        </Feature>
        <Feature headline="Integrity">
          <HeartIcon slot="icon" />
          <p slot="subheadline">
            We are driven by a commitment to ethical business practices, transparency, and most of all,
            maximizing shareholder value.
          </p>
        </Feature>
        <Feature headline="Collaboration">
          <GitDiffIcon slot="icon" />
          <p slot="subheadline">
            We believe teamwork makes the dream work, especially when that dream is offshoring local jobs to the
            lowest bidder.
          </p>
        </Feature>
        <Feature headline="Diversity">
          <User2Icon slot="icon" />
          <p slot="subheadline">
            Diversity can mean many things, but to us it mainly means hiring people from countries with the
            lowest labour costs.
          </p>
        </Feature>
        <Feature headline="Accountability">
          <TargetIcon slot="icon" />
          <p slot="subheadline">
            Our customers' success is our success and their failure is our failure, except in the legal sense
            where our liability is limited.
          </p>
        </Feature>
        <Feature headline="Quality">
          <StarIcon slot="icon" />
          <p slot="subheadline">
            We believe that you can move fast without breaking things, unless those things are labour laws in
            third world countries.
          </p>
        </Feature>
      </Fragment>
    </FeaturesThreeColumn>

    <!-- Call To Action -->
    <CallToActionSimple
      id="call-to-action"
      headline="Have anymore questions?"
    >
      <p slot="subheadline">Chat to someone on our sales team, who will make promises about our roadmap that we won't keep.</p>
      <div slot="cta" class="flex items-center gap-4">
        <ButtonLink href="#" size="lg">
          Chat with us
        </ButtonLink>

        <PlainButtonLink href="#" size="lg">
          Book a demo <ChevronIcon />
        </PlainButtonLink>
      </div>
    </CallToActionSimple>
  </Main>

  <FooterWithLinkCategories id="footer">
    <Fragment slot="links">
      <FooterCategory title="Product">
        <FooterLink href="#">Features</FooterLink>
        <FooterLink href="#">Pricing</FooterLink>
        <FooterLink href="#">Integrations</FooterLink>
      </FooterCategory>
      <FooterCategory title="Company">
        <FooterLink href="#">About</FooterLink>
        <FooterLink href="#">Careers</FooterLink>
        <FooterLink href="#">Blog</FooterLink>
        <FooterLink href="#">Press Kit</FooterLink>
      </FooterCategory>
      <FooterCategory title="Resources">
        <FooterLink href="#">Help Center</FooterLink>
        <FooterLink href="#">API Docs</FooterLink>
        <FooterLink href="#">Status</FooterLink>
        <FooterLink href="#">Contact</FooterLink>
      </FooterCategory>
      <FooterCategory title="Legal">
        <FooterLink href="#">Privacy Policy</FooterLink>
        <FooterLink href="#">Terms of Service</FooterLink>
        <FooterLink href="#">Security</FooterLink>
      </FooterCategory>
      <FooterCategory title="Connect">
        <FooterLink href="#">X</FooterLink>
        <FooterLink href="#">GitHub</FooterLink>
        <FooterLink href="#">YouTube</FooterLink>
      </FooterCategory>
    </Fragment>
    <span slot="fineprint">© 2025 Oatmeal, Inc.</span>
  </FooterWithLinkCategories>
</Base>
