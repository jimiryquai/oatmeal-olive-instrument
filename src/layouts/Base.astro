---
import { getMenu, getSiteSettings } from "emdash";
import { EmDashHead } from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import NavbarWithLinksActionsAndCenteredLogo from "@/components/sections/NavbarWithLinksActionsAndCenteredLogo.astro";
import NavbarLink from "@/components/sections/NavbarLink.astro";
import NavbarLogo from "@/components/sections/NavbarLogo.astro";
import FooterWithNewsletterFormCategoriesAndSocialIcons from "@/components/sections/FooterWithNewsletterFormCategoriesAndSocialIcons.astro";
import FooterCategory from "@/components/sections/FooterCategory.astro";
import FooterLink from "@/components/sections/FooterLink.astro";
import SocialLink from "@/components/sections/SocialLink.astro";
import NewsletterForm from "@/components/sections/NewsletterForm.astro";
import ButtonLink from '@/components/elements/ButtonLink.astro'
import PlainButtonLink from '@/components/elements/PlainButtonLink.astro';
import XIcon from "@/components/icons/social/x-icon.astro";
import GitHubIcon from "@/components/icons/social/github-icon.astro";
import YouTubeIcon from "@/components/icons/social/youtube-icon.astro";
import "../styles/globals.css";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	hideHeaderFooter?: boolean;
}

const { title, description, image, hideHeaderFooter = false } = Astro.props;
const settings = hideHeaderFooter ? null : await getSiteSettings();
const siteTitle = settings?.title || "Oatmeal";
const fullTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const siteDescription =
	settings?.tagline || "Customer support that feels like a conversation.";
const rawLogo = settings?.logo as any;
const siteLogo = rawLogo?.url ? { mediaId: rawLogo.mediaId, alt: rawLogo.alt, url: rawLogo.url } : null;

const [primaryMenu, footerProduct, footerCompany, footerResources, footerLegal] = hideHeaderFooter
	? [null, null, null, null, null]
	: await Promise.all([
			getMenu("primary"),
			getMenu("footer_product"),
			getMenu("footer_company"),
			getMenu("footer_resources"),
			getMenu("footer_legal"),
		]);

const pageCtx = createPublicPageContext({
	Astro,
	kind: "custom",
	pageType: "website",
	title: fullTitle,
	pageTitle: title ?? siteTitle,
	description: description || siteDescription,
	canonical: Astro.url.href,
	image,
	seo: { ogImage: image },
	siteName: siteTitle,
});
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{fullTitle}</title>
		<EmDashHead page={pageCtx} />
		<script is:inline>
			// Apply theme immediately to prevent flash
			(function () {
				var c = document.cookie;
				var i = c.indexOf("theme=");
				var theme = i >= 0 ? c.slice(i + 6).split(";")[0] : null;
				if (theme === "dark" || theme === "light") {
					document.documentElement.classList.add(theme);
				} else if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
					document.documentElement.classList.add("dark");
				}
			})();
		</script>
	</head>
	<body class="bg-olive-100 text-olive-950 antialiased dark:bg-olive-950 dark:text-white transition-colors duration-200">
		{!hideHeaderFooter && (
			<NavbarWithLinksActionsAndCenteredLogo
				id="navbar"
			>
				<Fragment slot="links">
					{
						primaryMenu?.items.map((item) => (
							<NavbarLink href={item.url}>{item.label}</NavbarLink>
						))
					}
				</Fragment>
				<NavbarLogo href="/" slot="logo">
					{
						siteLogo && (
							<img src={siteLogo.url} alt={siteLogo.alt || siteTitle} class="h-7 w-auto" />
						)
					}
					{
						!siteLogo && (
							<img
								src="/img/logos/oatmeal-instrument-color-olive-950.svg"
								alt={siteTitle}
								class="dark:hidden h-7 w-auto"
							/>
						)
					}
					{
						!siteLogo && (
							<img
								src="/img/logos/oatmeal-instrument-color-white.svg"
								alt={siteTitle}
								class="not-dark:hidden h-7 w-auto"
							/>
						)
					}
				</NavbarLogo>
				<Fragment slot="actions">
					<PlainButtonLink href="/_emdash/admin" class="max-sm:hidden">
						Log in
					</PlainButtonLink>
					<ButtonLink href="#">Get started</ButtonLink>
				</Fragment>
			</NavbarWithLinksActionsAndCenteredLogo>
		)}

		<main>
			<slot />
		</main>

		{!hideHeaderFooter && (
			<FooterWithNewsletterFormCategoriesAndSocialIcons
				id="footer"
			>
				<NewsletterForm
					slot="cta"
					headline="Stay in the loop"
					subheadline="Get customer support tips, product updates and customer stories that you can archive as soon as they arrive."
					action="#"
				/>
				<Fragment slot="links">
					{footerProduct && footerProduct.items.length > 0 && (
						<FooterCategory title="Product">
							{footerProduct.items.map((item) => (
								<FooterLink href={item.url}>{item.label}</FooterLink>
							))}
						</FooterCategory>
					)}
					{footerCompany && footerCompany.items.length > 0 && (
						<FooterCategory title="Company">
							{footerCompany.items.map((item) => (
								<FooterLink href={item.url}>{item.label}</FooterLink>
							))}
						</FooterCategory>
					)}
					{footerResources && footerResources.items.length > 0 && (
						<FooterCategory title="Resources">
							{footerResources.items.map((item) => (
								<FooterLink href={item.url}>{item.label}</FooterLink>
							))}
						</FooterCategory>
					)}
					{footerLegal && footerLegal.items.length > 0 && (
						<FooterCategory title="Legal">
							{footerLegal.items.map((item) => (
								<FooterLink href={item.url}>{item.label}</FooterLink>
							))}
						</FooterCategory>
					)}
				</Fragment>
				<span slot="fineprint">
					&copy; {new Date().getFullYear()} {siteTitle}, Inc.
				</span>
				<Fragment slot="socialLinks">
					<SocialLink href="https://x.com" name="X">
						<XIcon />
					</SocialLink>
					<SocialLink href="https://github.com" name="GitHub">
						<GitHubIcon />
					</SocialLink>
					<SocialLink href="https://www.youtube.com" name="YouTube">
						<YouTubeIcon />
					</SocialLink>
				</Fragment>
			</FooterWithNewsletterFormCategoriesAndSocialIcons>
		)}
	</body>
</html>
