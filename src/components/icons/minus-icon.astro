---
import { clsx } from 'clsx/lite'

interface Props {
  class?: string;
  [key: string]: any;
}

const { class: className, ...props } = Astro.props;
---
<svg
  width="13"
  height="1"
  viewBox="0 0 13 1"
  fill="none"
  stroke="currentColor"
  stroke-width="1"
  role="img"
  class={clsx('inline-block', className)}
  {...props}
>
  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" d="M12.505.5h-12" />
</svg>
