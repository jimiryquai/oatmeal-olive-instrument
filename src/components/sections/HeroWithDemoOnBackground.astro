---
import { clsx } from 'clsx/lite'
import Container from '../elements/container.astro'
import Heading from '../elements/heading.astro'
import Wallpaper from '../elements/wallpaper.astro'

interface Props {
  eyebrow?: string
  headline?: string
  subheadline?: string
  class?: string
  [key: string]: any
}

const { class: className, eyebrow, headline, subheadline, ...props } = Astro.props
---
<section class={clsx('flex flex-col gap-16 px-2 pb-16', className)} {...props}>
  <Wallpaper class="rounded-lg" color="green">
    <div class="-mx-2 sm:px-6 md:px-12 lg:px-0">
      <Container class="flex flex-col gap-16">
        <div class="flex gap-x-10 gap-y-16 max-lg:flex-col sm:gap-y-24">
          <div class="flex shrink-0 flex-col items-start gap-6 pt-16 sm:pt-32 lg:basis-2xl lg:py-40">
            {eyebrow}
            <slot name="eyebrow" />
            <Heading class="max-w-5xl" color="light">
              {headline}
              <slot name="headline" />
            </Heading>
            {(subheadline || Astro.slots.has('subheadline')) && (
              <div class="flex max-w-3xl flex-col gap-4 text-lg/8 text-white/70">
                {subheadline}
                <slot name="subheadline" />
              </div>
            )}
            <slot name="cta" />
          </div>
          <div class="lg:pt-24">
            <div class="relative h-72 sm:h-92 md:h-125 lg:size-full">
              <div class="absolute inset-y-0 left-0 flex w-screen overflow-hidden *:h-full *:w-auto *:max-w-none max-lg:rounded-t-lg lg:rounded-tl-lg">
                <slot name="demo" />
              </div>
            </div>
          </div>
        </div>
      </Container>
    </div>
  </Wallpaper>
  <Container>
    <slot name="footer" />
  </Container>
</section>
