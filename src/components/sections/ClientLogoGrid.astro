---
import LogoGrid from '../elements/logo-grid.astro'
import Logo from '../elements/logo.astro'

import logo9Black from '@/assets/logos/9-color-black-height-32.svg'
import logo9White from '@/assets/logos/9-color-white-height-32.svg'
import logo10Black from '@/assets/logos/10-color-black-height-32.svg'
import logo10White from '@/assets/logos/10-color-white-height-32.svg'
import logo11Black from '@/assets/logos/11-color-black-height-32.svg'
import logo11White from '@/assets/logos/11-color-white-height-32.svg'
import logo12Black from '@/assets/logos/12-color-black-height-32.svg'
import logo12White from '@/assets/logos/12-color-white-height-32.svg'
import logo13Black from '@/assets/logos/13-color-black-height-32.svg'
import logo13White from '@/assets/logos/13-color-white-height-32.svg'
import logo8Black from '@/assets/logos/8-color-black-height-32.svg'
import logo8White from '@/assets/logos/8-color-white-height-32.svg'
---
<LogoGrid>
  <Logo>
    <img
      src={logo9Black.src}
      class="dark:hidden"
      alt=""
      width={51}
      height={32}
    />
    <img
      src={logo9White.src}
      class="bg-black/75 not-dark:hidden"
      alt=""
      width={51}
      height={32}
    />
  </Logo>
  <Logo>
    <img
      src={logo10Black.src}
      class="dark:hidden"
      alt=""
      width={70}
      height={32}
    />
    <img
      src={logo10White.src}
      class="bg-black/75 not-dark:hidden"
      alt=""
      width={70}
      height={32}
    />
  </Logo>
  <Logo>
    <img
      src={logo11Black.src}
      class="dark:hidden"
      alt=""
      width={100}
      height={32}
    />
    <img
      src={logo11White.src}
      class="bg-black/75 not-dark:hidden"
      alt=""
      width={100}
      height={32}
    />
  </Logo>
  <Logo>
    <img
      src={logo12Black.src}
      class="dark:hidden"
      alt=""
      width={85}
      height={32}
    />
    <img
      src={logo12White.src}
      class="bg-black/75 not-dark:hidden"
      alt=""
      width={85}
      height={32}
    />
  </Logo>
  <Logo>
    <img
      src={logo13Black.src}
      class="dark:hidden"
      alt=""
      width={75}
      height={32}
    />
    <img
      src={logo13White.src}
      class="bg-black/75 not-dark:hidden"
      alt=""
      width={75}
      height={32}
    />
  </Logo>
  <Logo>
    <img
      src={logo8Black.src}
      class="dark:hidden"
      alt=""
      width={85}
      height={32}
    />
    <img
      src={logo8White.src}
      class="bg-black/75 not-dark:hidden"
      alt=""
      width={85}
      height={32}
    />
  </Logo>
</LogoGrid>
