---
import Section from '../elements/section.astro'

interface Props {
  eyebrow?: string
  headline?: string
  subheadline?: string
  cta?: string
  class?: string
  [key: string]: any
}

const { ...props } = Astro.props
---
<Section {...props}>
  <slot name="eyebrow" slot="eyebrow" />
  <slot name="headline" slot="headline" />
  <slot name="subheadline" slot="subheadline" />
  <slot name="cta" slot="cta" />
  <ul role="list" class="grid grid-cols-2 gap-x-2 gap-y-10 md:grid-cols-3">
    <slot />
  </ul>
</Section>
