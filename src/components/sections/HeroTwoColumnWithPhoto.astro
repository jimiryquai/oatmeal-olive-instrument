---
import { clsx } from 'clsx/lite'
import Container from '../elements/container.astro'
import Heading from '../elements/heading.astro'
import Text from '../elements/text.astro'

interface Props {
  eyebrow?: string
  headline?: string
  subheadline?: string
  class?: string
  [key: string]: any
}

const { class: className, eyebrow, headline, subheadline, ...props } = Astro.props
---
<section class={clsx('py-16', className)} {...props}>
  <Container class="flex gap-16 max-xl:flex-col">
    <div class="flex flex-1 flex-col items-start justify-center gap-6">
      {eyebrow}
      <slot name="eyebrow" />
      <Heading class="max-w-5xl">
        {headline}
        <slot name="headline" />
      </Heading>
      {(subheadline || Astro.slots.has('subheadline')) && (
        <Text size="lg" class="flex max-w-3xl flex-col gap-4">
          {subheadline}
          <slot name="subheadline" />
        </Text>
      )}
      <slot name="cta" />
    </div>
    <div class="flex flex-1 overflow-hidden rounded-xl outline -outline-offset-1 outline-black/5 *:object-cover dark:outline-white/5">
      <slot name="photo" />
    </div>
  </Container>
</section>
