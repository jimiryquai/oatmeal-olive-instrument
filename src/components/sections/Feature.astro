---
import { clsx } from 'clsx/lite'

interface Props {
  headline?: string
  class?: string
  [key: string]: any
}

const { headline, class: className, ...props } = Astro.props
---
<div class={clsx('rounded-lg bg-olive-950/2.5 p-2 dark:bg-white/5', className)} {...props}>
  <div class="relative overflow-hidden rounded-sm dark:after:absolute dark:after:inset-0 dark:after:rounded-sm dark:after:outline-1 dark:after:-outline-offset-1 dark:after:outline-white/10">
    <slot name="demo" />
  </div>
  <div class="flex flex-col gap-4 p-6 sm:p-10 lg:p-6">
    <div>
      <h3 class="text-base/8 font-medium text-olive-950 dark:text-white">
        {headline || <slot name="headline" />}
      </h3>
      <div class="mt-2 flex flex-col gap-4 text-sm/7 text-olive-700 dark:text-olive-400">
        <slot name="subheadline" />
        <slot />
      </div>
    </div>
    <slot name="cta" />
  </div>
</div>
