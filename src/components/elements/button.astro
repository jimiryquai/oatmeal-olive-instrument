---
import { clsx } from 'clsx/lite'

interface Props {
  href?: string
  size?: 'md' | 'lg'
  color?: 'dark/light' | 'light'
  variant?: 'solid' | 'soft' | 'plain'
  class?: string
  type?: 'button' | 'submit' | 'reset'
  [key: string]: any
}

const {
  href,
  size = 'md',
  color = 'dark/light',
  variant = 'solid',
  class: className,
  type = 'button',
  ...props
} = Astro.props

const sizes = {
  md: 'px-3 py-1',
  lg: 'px-4 py-2',
}

const baseClasses = 'inline-flex shrink-0 items-center justify-center gap-1 rounded-full text-sm/7 font-medium'

let variantClasses = ''
if (variant === 'solid') {
  if (color === 'dark/light') {
    variantClasses = 'bg-olive-950 text-white hover:bg-olive-800 dark:bg-olive-300 dark:text-olive-950 dark:hover:bg-olive-200'
  } else {
    variantClasses = 'hover bg-white text-olive-950 hover:bg-olive-100 dark:bg-olive-100 dark:hover:bg-white'
  }
} else if (variant === 'soft') {
  variantClasses = 'bg-olive-950/10 text-olive-950 hover:bg-olive-950/15 dark:bg-white/10 dark:text-white dark:hover:bg-white/20'
} else if (variant === 'plain') {
  if (color === 'dark/light') {
    variantClasses = 'text-olive-950 hover:bg-olive-950/10 dark:text-white dark:hover:bg-white/10 gap-2'
  } else {
    variantClasses = 'text-white hover:bg-white/15 dark:hover:bg-white/10 gap-2'
  }
}

const classes = clsx(baseClasses, variantClasses, sizes[size], className)
---
{
  href ? (
    <a href={href} class={classes} {...props}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes} {...props}>
      <slot />
    </button>
  )
}
