---
import TestimonialThreeColumnGrid from "@/components/sections/TestimonialThreeColumnGrid.astro";
import Testimonial from "@/components/sections/Testimonial.astro";
import TestimonialTwoColumnWithLargePhoto from "@/components/sections/TestimonialTwoColumnWithLargePhoto.astro";
import { getEmDashEntry, getEmDashCollection } from "emdash";
import { Image } from "emdash/ui";

interface TestimonialItem {
	quote: string;
	author: string;
	role?: string;
	company?: string;
	avatar?: any;
}

interface Props {
	node: {
		_key?: string;
		headline?: string;
		testimonials: TestimonialItem[];
		serviceSlug?: string;
	};
}

const { node } = Astro.props;
const { _key, headline, testimonials = [], serviceSlug } = node;

let testimonialsData = testimonials;

if (serviceSlug) {
	const { entry: service } = await getEmDashEntry("services", serviceSlug);
	if (service) {
		const { entries } = await getEmDashCollection("testimonials", {
			where: { service: service.data.id as string },
		});
		if (entries && entries.length > 0) {
			testimonialsData = entries.map((entry) => ({
				quote: String(entry.data.quote ?? ""),
				author: String(entry.data.author ?? ""),
				role: entry.data.role ? String(entry.data.role) : undefined,
				company: entry.data.company ? String(entry.data.company) : undefined,
				avatar: entry.data.avatar || undefined,
			}));
		}
	}
}

const isSingle = testimonialsData.length === 1;
const singleTestimonial = isSingle ? testimonialsData[0] : null;
const singleByline = singleTestimonial
	? [singleTestimonial.role, singleTestimonial.company]
			.filter(Boolean)
			.join(" at ")
	: "";

const subheadlineText = headline
	? "We've given these customers a significant discount in exchange for their honest reviews."
	: undefined;
---

{
	isSingle && singleTestimonial && (
		<TestimonialTwoColumnWithLargePhoto
			id={_key || "testimonial"}
			name={singleTestimonial.author}
			byline={singleByline}
		>
			<p slot="quote">{singleTestimonial.quote}</p>
			{singleTestimonial.avatar && (
				<Image
					slot="img"
					image={singleTestimonial.avatar}
					alt=""
					width={1400}
					height={1000}
					class="not-dark:bg-white/75 dark:bg-black/75 w-full h-auto object-cover"
				/>
			)}
		</TestimonialTwoColumnWithLargePhoto>
	)
}

{
	!isSingle && testimonialsData.length > 0 && (
		<TestimonialThreeColumnGrid
			id={_key || "testimonial"}
			headline={headline}
			subheadline={subheadlineText}
		>
			{testimonialsData.map((t) => {
				const byline = [t.role, t.company].filter(Boolean).join(" at ");
				return (
					<Testimonial name={t.author} byline={byline}>
						<p slot="quote">{t.quote}</p>
						{t.avatar && (
							<Image
								slot="img"
								image={t.avatar}
								alt=""
								class="not-dark:bg-white/75 dark:bg-black/75 w-full h-auto"
								width={160}
								height={160}
							/>
						)}
					</Testimonial>
				);
			})}
		</TestimonialThreeColumnGrid>
	)
}

