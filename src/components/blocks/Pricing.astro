---
import PricingMultiTier from "@/components/sections/PricingMultiTier.astro";
import Plan from "@/components/sections/PricingPlan.astro";
import SoftButtonLink from "@/components/elements/SoftButtonLink.astro";
import ButtonLink from "@/components/elements/ButtonLink.astro";
import { getEmDashEntry, getEmDashCollection } from "emdash";

interface RawPlan {
	name: string;
	price: string;
	period?: string;
	description?: string;
	// Features are stored as a newline-separated string
	features?: string;
	ctaLabel?: string;
	ctaUrl?: string;
	highlighted?: boolean;
}

interface Props {
	node: {
		_key?: string;
		headline?: string;
		plans: RawPlan[];
		serviceSlug?: string;
	};
}

const { node } = Astro.props;
const { _key, headline, plans = [], serviceSlug } = node;

let plansData = plans;

if (serviceSlug) {
	const { entry: service } = await getEmDashEntry("services", serviceSlug);
	if (service) {
		const { entries } = await getEmDashCollection("pricing", {
			where: { service: service.data.id as string },
		});
		if (entries && entries.length > 0) {
			plansData = entries.map((entry) => ({
				name: String(entry.data.name ?? ""),
				price: String(entry.data.price ?? ""),
				period: entry.data.period ? String(entry.data.period) : undefined,
				description: entry.data.description ? String(entry.data.description) : undefined,
				features: entry.data.features ? String(entry.data.features) : undefined,
				ctaLabel: entry.data.cta_label ? String(entry.data.cta_label) : undefined,
				ctaUrl: entry.data.cta_url ? String(entry.data.cta_url) : undefined,
				highlighted: entry.data.highlighted !== undefined ? Boolean(entry.data.highlighted) : undefined,
			}));
		}
	}
}

const parsedPlans = plansData.map((plan) => ({
	...plan,
	featuresList: (plan.features ?? "")
		.split("\n")
		.map((s) => s.trim())
		.filter(Boolean),
}));
---

<PricingMultiTier
	id={_key || "pricing"}
	headline={headline}
>
	<Fragment slot="plans">
		{
			parsedPlans.map((plan) => (
				<Plan
					name={plan.name}
					price={plan.price}
					period={plan.period}
					badge={plan.highlighted ? "Most popular" : undefined}
					features={plan.featuresList}
				>
					<div slot="subheadline">{plan.description}</div>
					<div slot="cta" class="contents">
						{plan.highlighted && (
							<ButtonLink href={plan.ctaUrl || "#"} size="lg">
								{plan.ctaLabel || "Start free trial"}
							</ButtonLink>
						)}
						{!plan.highlighted && (
							<SoftButtonLink href={plan.ctaUrl || "#"} size="lg">
								{plan.ctaLabel || "Start free trial"}
							</SoftButtonLink>
						)}
					</div>
				</Plan>
			))
		}
	</Fragment>
</PricingMultiTier>
