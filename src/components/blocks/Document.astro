---
import DocumentCentered from "@/components/sections/DocumentCentered.astro";

interface Props {
	node: {
		_key?: string;
		headline: string;
		subheadline?: string;
		content?: string;
	};
}

const { node } = Astro.props;
const { _key, headline, subheadline, content = "" } = node;
---

<DocumentCentered
	id={_key || "document"}
	headline={headline}
	subheadline={subheadline}
>
	<div set:html={content} />
</DocumentCentered>
