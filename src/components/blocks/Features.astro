---
import FeaturesTwoColumnWithDemos from "@/components/sections/FeaturesTwoColumnWithDemos.astro";
import Feature from "@/components/sections/Feature.astro";
import Screenshot from "@/components/elements/screenshot.astro";
import Link from "@/components/elements/link.astro";
import ArrowNarrowRightIcon from "@/components/icons/arrow-narrow-right-icon.astro";
import { Image as AstroImage } from "astro:assets";

import screenshotLeft1000 from "@/assets/screenshots/1-left-1000-top-800.webp";
import screenshotOliveLeft1000 from "@/assets/screenshots/1-color-olive-left-1000-top-800.webp";
import screenshotLeft1800Top660 from "@/assets/screenshots/1-left-1800-top-660.webp";
import screenshotOliveLeft1800Top660 from "@/assets/screenshots/1-color-olive-left-1800-top-660.webp";
import screenshotLeft1300 from "@/assets/screenshots/1-left-1300-top-1300.webp";
import screenshotOliveLeft1300 from "@/assets/screenshots/1-color-olive-left-1300-top-1300.webp";
import screenshotLeft1800Top1250 from "@/assets/screenshots/1-left-1800-top-1250.webp";
import screenshotOliveLeft1800Top1250 from "@/assets/screenshots/1-color-olive-left-1800-top-1250.webp";

import screenshotRight1000 from "@/assets/screenshots/1-right-1000-top-800.webp";
import screenshotOliveRight1000 from "@/assets/screenshots/1-color-olive-right-1000-top-800.webp";
import screenshotRight1800Top660 from "@/assets/screenshots/1-right-1800-top-660.webp";
import screenshotOliveRight1800Top660 from "@/assets/screenshots/1-color-olive-right-1800-top-660.webp";
import screenshotRight1300 from "@/assets/screenshots/1-right-1300-top-1300.webp";
import screenshotOliveRight1300 from "@/assets/screenshots/1-color-olive-right-1300-top-1300.webp";
import screenshotRight1800Top1250 from "@/assets/screenshots/1-right-1800-top-1250.webp";
import screenshotOliveRight1800Top1250 from "@/assets/screenshots/1-color-olive-right-1800-top-1250.webp";

interface FeatureItem {
	title: string;
	description: string;
}

interface Props {
	node: {
		_key?: string;
		headline?: string;
		subheadline?: string;
		features: FeatureItem[];
	};
}

const { node } = Astro.props;
const { _key, headline, subheadline, features = [] } = node;
---

<FeaturesTwoColumnWithDemos
	id={_key || "features"}
	eyebrow="Powerful features"
	headline={headline}
	subheadline={subheadline}
>
	<Fragment slot="features">
		{
			features.map((feature) => {
				const isInboxAgent = feature.title
					.toLowerCase()
					.includes("agent");

				return (
					<Feature headline={feature.title}>
						<div slot="subheadline">{feature.description}</div>

						<Link slot="cta" href="#">
							See how it works <ArrowNarrowRightIcon />
						</Link>

						<div slot="demo" class="contents">
							{!isInboxAgent && (
								<Screenshot
									wallpaper="purple"
									placement="bottom-right"
								>
									<AstroImage
										src={screenshotLeft1000}
										alt=""
										class="bg-white/75 sm:hidden dark:hidden"
										width="1000"
										height="800"
									/>
									<AstroImage
										src={screenshotOliveLeft1000}
										alt=""
										class="bg-black/75 not-dark:hidden sm:hidden"
										width="1000"
										height="800"
									/>
									<AstroImage
										src={screenshotLeft1800Top660}
										alt=""
										class="bg-white/75 max-sm:hidden lg:hidden dark:hidden"
										width="1800"
										height="660"
									/>
									<AstroImage
										src={screenshotOliveLeft1800Top660}
										alt=""
										class="bg-black/75 not-dark:hidden max-sm:hidden lg:hidden"
										width="1800"
										height="660"
									/>
									<AstroImage
										src={screenshotLeft1300}
										alt=""
										class="bg-white/75 max-lg:hidden xl:hidden dark:hidden"
										width="1300"
										height="1300"
									/>
									<AstroImage
										src={screenshotOliveLeft1300}
										alt=""
										class="bg-black/75 not-dark:hidden max-lg:hidden xl:hidden"
										width="1300"
										height="1300"
									/>
									<AstroImage
										src={screenshotLeft1800Top1250}
										alt=""
										class="bg-white/75 max-xl:hidden dark:hidden"
										width="1800"
										height="1250"
									/>
									<AstroImage
										src={screenshotOliveLeft1800Top1250}
										alt=""
										class="bg-black/75 not-dark:hidden max-xl:hidden"
										width="1800"
										height="1250"
									/>
								</Screenshot>
							)}
							{isInboxAgent && (
								<Screenshot
									wallpaper="blue"
									placement="bottom-left"
								>
									<AstroImage
										src={screenshotRight1000}
										alt=""
										class="bg-white/75 sm:hidden dark:hidden"
										width="1000"
										height="800"
									/>
									<AstroImage
										src={screenshotOliveRight1000}
										alt=""
										class="bg-black/75 not-dark:hidden sm:hidden"
										width="1000"
										height="800"
									/>
									<AstroImage
										src={screenshotRight1800Top660}
										alt=""
										class="bg-white/75 max-sm:hidden lg:hidden dark:hidden"
										width="1800"
										height="660"
									/>
									<AstroImage
										src={screenshotOliveRight1800Top660}
										alt=""
										class="bg-black/75 not-dark:hidden max-sm:hidden lg:hidden"
										width="1800"
										height="660"
									/>
									<AstroImage
										src={screenshotRight1300}
										alt=""
										class="bg-white/75 max-lg:hidden xl:hidden dark:hidden"
										width="1300"
										height="1300"
									/>
									<AstroImage
										src={screenshotOliveRight1300}
										alt=""
										class="bg-black/75 not-dark:hidden max-lg:hidden xl:hidden"
										width="1300"
										height="1300"
									/>
									<AstroImage
										src={screenshotRight1800Top1250}
										alt=""
										class="bg-white/75 max-xl:hidden dark:hidden"
										width="1800"
										height="1250"
									/>
									<AstroImage
										src={screenshotOliveRight1800Top1250}
										alt=""
										class="bg-black/75 not-dark:hidden max-xl:hidden"
										width="1800"
										height="1250"
									/>
								</Screenshot>
							)}
						</div>
					</Feature>
				);
			})
		}
	</Fragment>
</FeaturesTwoColumnWithDemos>
