---
import StatsWithGraph from "@/components/sections/StatsWithGraph.astro";
import Stat from "@/components/sections/Stat.astro";

interface StatItem {
	stat: string;
	text: string;
}

interface Props {
	node: {
		_key?: string;
		eyebrow?: string;
		headline?: string;
		subheadline?: string;
		stats: StatItem[];
	};
}

const { node } = Astro.props;
const { _key, eyebrow, headline, subheadline, stats = [] } = node;
---

<StatsWithGraph
	id={_key || "stats"}
	eyebrow={eyebrow}
	headline={headline}
	subheadline={subheadline}
>
	{stats.map((s) => <Stat stat={s.stat} text={s.text} />)}
</StatsWithGraph>
