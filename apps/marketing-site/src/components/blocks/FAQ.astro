---
import FAQsAccordion from "@jamesryan/ui/components/sections/FAQsAccordion.astro";
import FAQsTwoColumnAccordion from "@jamesryan/ui/components/sections/FAQsTwoColumnAccordion.astro";
import Faq from "@jamesryan/ui/components/sections/Faq.astro";
import { getEmDashEntry, getEmDashCollection } from "emdash";

interface Props {
	node: {
		_key?: string;
		headline?: string;
		subheadline?: string;
		variation?: "two-column" | "centered";
		items: Array<{
			question: string;
			answer: string;
		}>;
		serviceSlug?: string;
	};
}

const { node } = Astro.props;
const {
	_key,
	headline,
	subheadline,
	variation = "two-column",
	items = [],
	serviceSlug,
} = node;

let faqItems = items;

if (serviceSlug) {
	const { entry: service } = await getEmDashEntry("services", serviceSlug);
	if (service) {
		const { entries } = await getEmDashCollection("faqs", {
			where: { service: service.data.id as string },
		});
		if (entries && entries.length > 0) {
			faqItems = entries.map((entry) => ({
				question: String(entry.data.question ?? ""),
				answer: String(entry.data.answer ?? ""),
			}));
		}
	}
}

const isTwoColumn = variation === "two-column";
---

{
	isTwoColumn && (
		<FAQsTwoColumnAccordion
			id={_key || "faqs"}
			headline={headline || "Questions & Answers"}
			subheadline={subheadline}
		>
			{faqItems.map((item, idx) => (
				<Faq
					id={`faq-item-${idx}`}
					question={item.question}
					answer={item.answer}
				/>
			))}
		</FAQsTwoColumnAccordion>
	)
}

{
	!isTwoColumn && (
		<FAQsAccordion
			id={_key || "faqs"}
			headline={headline || "Questions & Answers"}
			subheadline={subheadline}
		>
			{faqItems.map((item, idx) => (
				<Faq
					id={`faq-item-${idx}`}
					question={item.question}
					answer={item.answer}
				/>
			))}
		</FAQsAccordion>
	)
}
