---
import HeroLeftAlignedWithDemo from "@jamesryan/ui/components/sections/HeroLeftAlignedWithDemo.astro";
import HeroLeftAlignedWithPhoto from "@jamesryan/ui/components/sections/HeroLeftAlignedWithPhoto.astro";
import PricingHeroMultiTier from "@jamesryan/ui/components/sections/PricingHeroMultiTier.astro";
import Plan from "@jamesryan/ui/components/sections/PricingPlan.astro";
import AnnouncementBadge from "@jamesryan/ui/components/elements/announcement-badge.astro";
import ButtonLink from "@jamesryan/ui/components/elements/ButtonLink.astro";
import PlainButtonLink from "@jamesryan/ui/components/elements/PlainButtonLink.astro";
import SoftButtonLink from "@jamesryan/ui/components/elements/SoftButtonLink.astro";
import ArrowNarrowRightIcon from "@jamesryan/ui/components/icons/arrow-narrow-right-icon.astro";
import ClientLogoGrid from "@jamesryan/ui/components/sections/ClientLogoGrid.astro";
import { getEmDashEntry, getEmDashCollection } from "emdash";
import { Image as AstroImage } from "astro:assets";
import Screenshot from "@jamesryan/ui/components/elements/screenshot.astro";

import screenshot1Left1670 from "@jamesryan/ui/assets/screenshots/1-left-1670-top-1408.webp";
import screenshot1OliveLeft1670 from "@jamesryan/ui/assets/screenshots/1-color-olive-left-1670-top-1408.webp";
import screenshot1Left2000 from "@jamesryan/ui/assets/screenshots/1-left-2000-top-1408.webp";
import screenshot1OliveLeft2000 from "@jamesryan/ui/assets/screenshots/1-color-olive-left-2000-top-1408.webp";
import screenshot1Full from "@jamesryan/ui/assets/screenshots/1.webp";
import screenshot1OliveFull from "@jamesryan/ui/assets/screenshots/1-color-olive.webp";

interface RawHeroPlan {
	name: string;
	priceMonthly: string;
	priceYearly: string;
	description?: string;
	features?: string;
	ctaLabel?: string;
	ctaUrl?: string;
	badge?: string;
	highlighted?: boolean;
}

interface Props {
	node: {
		_key?: string;
		variation?: "left-aligned-with-demo" | "left-aligned-with-photo" | "pricing-hero-multi-tier";
		headline: string;
		subheadline?: string;
		primaryCtaLabel?: string;
		primaryCtaUrl?: string;
		secondaryCtaLabel?: string;
		secondaryCtaUrl?: string;
		photoUrl?: string;
		plans?: RawHeroPlan[];
		eyebrowText?: string;
		eyebrowUrl?: string;
		eyebrowCta?: string;
		serviceSlug?: string;
	};
}

const { node } = Astro.props;
const {
	_key,
	variation = "left-aligned-with-demo",
	headline,
	subheadline,
	primaryCtaLabel,
	primaryCtaUrl,
	secondaryCtaLabel,
	secondaryCtaUrl,
	photoUrl,
	plans,
	eyebrowText,
	eyebrowUrl,
	eyebrowCta,
	serviceSlug,
} = node;

let plansData = plans;

if (serviceSlug && variation === "pricing-hero-multi-tier") {
	const { entry: service } = await getEmDashEntry("services", serviceSlug);
	if (service) {
		const { entries } = await getEmDashCollection("pricing", {
			where: { service: service.data.id as string },
		});
		if (entries && entries.length > 0) {
			plansData = entries.map((entry) => ({
				name: String(entry.data.name ?? ""),
				priceMonthly: String(entry.data.price_monthly ?? entry.data.price ?? ""),
				priceYearly: String(entry.data.price_yearly ?? ""),
				description: entry.data.description ? String(entry.data.description) : undefined,
				features: entry.data.features ? String(entry.data.features) : undefined,
				ctaLabel: entry.data.cta_label ? String(entry.data.cta_label) : undefined,
				ctaUrl: entry.data.cta_url ? String(entry.data.cta_url) : undefined,
				badge: entry.data.badge ? String(entry.data.badge) : undefined,
				highlighted: entry.data.highlighted !== undefined ? Boolean(entry.data.highlighted) : undefined,
			}));
		}
	}
}

const hasEyebrow = eyebrowText && eyebrowUrl;
const hasCta = (primaryCtaLabel && primaryCtaUrl) || (secondaryCtaLabel && secondaryCtaUrl);
---

{
	variation === "pricing-hero-multi-tier" && (
		<PricingHeroMultiTier id={_key || "pricing"}>
			{hasEyebrow && (
				<AnnouncementBadge
					slot="eyebrow"
					href={eyebrowUrl}
					text={eyebrowText}
					cta={eyebrowCta}
				/>
			)}
			<Fragment slot="headline">{headline}</Fragment>
			{subheadline && <Fragment slot="subheadline">{subheadline}</Fragment>}

			<Fragment slot="monthly-plans">
				{plansData?.map((plan) => {
					const featuresList = (plan.features ?? "")
						.split("\n")
						.map((s) => s.trim())
						.filter(Boolean);
					return (
						<Plan
							name={plan.name}
							price={plan.priceMonthly}
							period="/month"
							badge={plan.badge}
							features={featuresList}
						>
							<div slot="subheadline">{plan.description}</div>
							<div slot="cta" class="contents">
								{plan.highlighted ? (
									<ButtonLink href={plan.ctaUrl || "#"} size="lg">
										{plan.ctaLabel || "Start free trial"}
									</ButtonLink>
								) : (
									<SoftButtonLink href={plan.ctaUrl || "#"} size="lg">
										{plan.ctaLabel || "Start free trial"}
									</SoftButtonLink>
								)}
							</div>
						</Plan>
					);
				})}
			</Fragment>

			<Fragment slot="yearly-plans">
				{plansData?.map((plan) => {
					const featuresList = (plan.features ?? "")
						.split("\n")
						.map((s) => s.trim())
						.filter(Boolean);
					return (
						<Plan
							name={plan.name}
							price={plan.priceYearly}
							period="/year"
							badge={plan.badge}
							features={featuresList}
						>
							<div slot="subheadline">{plan.description}</div>
							<div slot="cta" class="contents">
								{plan.highlighted ? (
									<ButtonLink href={plan.ctaUrl || "#"} size="lg">
										{plan.ctaLabel || "Start free trial"}
									</ButtonLink>
								) : (
									<SoftButtonLink href={plan.ctaUrl || "#"} size="lg">
										{plan.ctaLabel || "Start free trial"}
									</SoftButtonLink>
								)}
							</div>
						</Plan>
					);
				})}
			</Fragment>
		</PricingHeroMultiTier>
	)
}

{
	variation === "left-aligned-with-photo" && (
		<HeroLeftAlignedWithPhoto
			id={_key || "hero"}
			headline={headline}
			subheadline={subheadline}
		>
			{hasEyebrow && (
				<AnnouncementBadge
					slot="eyebrow"
					href={eyebrowUrl}
					text={eyebrowText}
					cta={eyebrowCta}
				/>
			)}
			{hasCta && (
				<div slot="cta" class="flex items-center gap-4">
					{primaryCtaLabel && primaryCtaUrl && (
						<ButtonLink href={primaryCtaUrl} size="lg">
							{primaryCtaLabel}
						</ButtonLink>
					)}
					{secondaryCtaLabel && secondaryCtaUrl && (
						<PlainButtonLink href={secondaryCtaUrl} size="lg">
							{secondaryCtaLabel} <ArrowNarrowRightIcon />
						</PlainButtonLink>
					)}
				</div>
			)}
			{photoUrl && (
				<img
					slot="photo"
					src={photoUrl}
					alt=""
					width="1800"
					height="945"
					class="not-dark:bg-white/75 dark:bg-black/75 w-full h-auto object-cover"
				/>
			)}
			<ClientLogoGrid slot="footer" />
		</HeroLeftAlignedWithPhoto>
	)
}

{
	variation !== "pricing-hero-multi-tier" && variation !== "left-aligned-with-photo" && (
		<HeroLeftAlignedWithDemo
			id={_key || "hero"}
			headline={headline}
			subheadline={subheadline}
		>
			{hasEyebrow && (
				<AnnouncementBadge
					slot="eyebrow"
					href={eyebrowUrl}
					text={eyebrowText}
					cta={eyebrowCta}
				/>
			)}
			{hasCta && (
				<div slot="cta" class="flex items-center gap-4">
					{primaryCtaLabel && primaryCtaUrl && (
						<ButtonLink href={primaryCtaUrl} size="lg">
							{primaryCtaLabel}
						</ButtonLink>
					)}
					{secondaryCtaLabel && secondaryCtaUrl && (
						<PlainButtonLink href={secondaryCtaUrl} size="lg">
							{secondaryCtaLabel} <ArrowNarrowRightIcon />
						</PlainButtonLink>
					)}
				</div>
			)}
			<div slot="demo" class="contents">
				<Screenshot class="rounded-md lg:hidden" wallpaper="green" placement="bottom-right">
					<AstroImage
						src={screenshot1Left1670}
						alt=""
						width="1670"
						height="1408"
						class="bg-white/75 md:hidden dark:hidden w-full h-auto"
					/>
					<AstroImage
						src={screenshot1OliveLeft1670}
						alt=""
						width="1670"
						height="1408"
						class="bg-black/75 not-dark:hidden md:hidden w-full h-auto"
					/>
					<AstroImage
						src={screenshot1Left2000}
						alt=""
						width="2000"
						height="1408"
						class="bg-white/75 max-md:hidden dark:hidden w-full h-auto"
					/>
					<AstroImage
						src={screenshot1OliveLeft2000}
						alt=""
						width="2000"
						height="1408"
						class="bg-black/75 not-dark:hidden max-md:hidden w-full h-auto"
					/>
				</Screenshot>
				<Screenshot class="rounded-lg max-lg:hidden" wallpaper="green" placement="bottom">
					<AstroImage
						src={screenshot1Full}
						alt=""
						class="bg-white/75 dark:hidden w-full h-auto"
						width="3440"
						height="1990"
					/>
					<AstroImage
						class="bg-black/75 not-dark:hidden w-full h-auto"
						src={screenshot1OliveFull}
						alt=""
						width="3440"
						height="1990"
					/>
				</Screenshot>
			</div>
			<ClientLogoGrid slot="footer" />
		</HeroLeftAlignedWithDemo>
	)
}
