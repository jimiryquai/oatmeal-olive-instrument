---
import Base from '../layouts/Base.astro'
import AnnouncementBadge from '@jamesryan/ui/components/elements/announcement-badge.astro'
import ButtonLink from '@jamesryan/ui/components/elements/ButtonLink.astro'
import PlainButtonLink from '@jamesryan/ui/components/elements/PlainButtonLink.astro'
import InstallCommand from '@jamesryan/ui/components/elements/install-command.astro'
import Link from '@jamesryan/ui/components/elements/link.astro'
import LogoGrid from '@jamesryan/ui/components/elements/logo-grid.astro'
import Logo from '@jamesryan/ui/components/elements/logo.astro'
import Main from '@jamesryan/ui/components/elements/main.astro'
import Screenshot from '@jamesryan/ui/components/elements/screenshot.astro'
import ChevronIcon from '@jamesryan/ui/components/icons/chevron-icon.astro'
import GitHubIcon from '@jamesryan/ui/components/icons/social/github-icon.astro'
import XIcon from '@jamesryan/ui/components/icons/social/x-icon.astro'
import YouTubeIcon from '@jamesryan/ui/components/icons/social/youtube-icon.astro'
import BrandCard from '@jamesryan/ui/components/sections/BrandCard.astro'
import BrandsCardsMultiColumn from '@jamesryan/ui/components/sections/BrandsCardsMultiColumn.astro'
import CallToActionSimple from '@jamesryan/ui/components/sections/CallToActionSimple.astro'
import Feature from '@jamesryan/ui/components/sections/StackedAlternatingFeature.astro'
import FeaturesStackedAlternatingWithDemos from '@jamesryan/ui/components/sections/FeaturesStackedAlternatingWithDemos.astro'
import FooterLink from '@jamesryan/ui/components/sections/FooterLink.astro'
import FooterWithLinksAndSocialIcons from '@jamesryan/ui/components/sections/FooterWithLinksAndSocialIcons.astro'
import SocialLink from '@jamesryan/ui/components/sections/SocialLink.astro'
import HeroCenteredWithDemo from '@jamesryan/ui/components/sections/HeroCenteredWithDemo.astro'
import NavbarLink from '@jamesryan/ui/components/sections/NavbarLink.astro'
import NavbarLogo from '@jamesryan/ui/components/sections/NavbarLogo.astro'
import NavbarWithLogoActionsAndLeftAlignedLinks from '@jamesryan/ui/components/sections/NavbarWithLogoActionsAndLeftAlignedLinks.astro'
import Stat from '@jamesryan/ui/components/sections/Stat.astro'
import StatsWithGraph from '@jamesryan/ui/components/sections/StatsWithGraph.astro'
import TestimonialTwoColumnWithLargePhoto from '@jamesryan/ui/components/sections/TestimonialTwoColumnWithLargePhoto.astro'
---

<Base hideHeaderFooter={true} title="Customer support that feels like a conversation" description="Simplify your shared inbox, collaborate effortlessly, and give every customer a reply that feels personal.">
  <NavbarWithLogoActionsAndLeftAlignedLinks id="navbar">
    <NavbarLogo slot="logo" href="#">
      <img
        src="/img/logos/oatmeal-instrument-color-olive-950.svg"
        alt="Oatmeal"
        class="dark:hidden"
        width={85}
        height={28}
      />
      <img
        src="/img/logos/oatmeal-instrument-color-white.svg"
        alt="Oatmeal"
        class="not-dark:hidden"
        width={85}
        height={28}
      />
    </NavbarLogo>
    <Fragment slot="links">
      <NavbarLink href="#">Pricing</NavbarLink>
      <NavbarLink href="#">About</NavbarLink>
      <NavbarLink href="#">Docs</NavbarLink>
      <NavbarLink href="/_emdash/admin" class="sm:hidden">
        Log in
      </NavbarLink>
    </Fragment>
    <Fragment slot="actions">
      <PlainButtonLink href="/_emdash/admin" class="max-sm:hidden">
        Log in
      </PlainButtonLink>
      <ButtonLink href="#">Get started</ButtonLink>
    </Fragment>
  </NavbarWithLogoActionsAndLeftAlignedLinks>

  <Main>
    <!-- Hero -->
    <HeroCenteredWithDemo id="hero">
      <AnnouncementBadge slot="eyebrow" href="#" text="Oatmeal raises 80M Series A funding" cta="Learn more" />
      <Fragment slot="headline">Customer support that feels like a conversation.</Fragment>
      <p slot="subheadline">
        Simplify your shared inbox, collaborate effortlessly, and give every customer a reply that feels personal
        — even if it was generated by a bot.
      </p>
      <InstallCommand slot="cta" class="min-w-xs" snippet="npm install oatmeal" />
      
      <Fragment slot="demo">
        <Screenshot class="rounded-md lg:hidden" wallpaper="green" placement="bottom-right">
          <img
            src="/img/screenshots/1-left-1670-top-1408.webp"
            alt=""
            width={1670}
            height={1408}
            class="md:hidden dark:hidden"
          />
          <img
            src="/img/screenshots/1-color-olive-left-1670-top-1408.webp"
            alt=""
            width={1670}
            height={1408}
            class="not-dark:hidden md:hidden"
          />
          <img
            src="/img/screenshots/1-left-2000-top-1408.webp"
            alt=""
            width={2000}
            height={1408}
            class="max-md:hidden dark:hidden"
          />
          <img
            src="/img/screenshots/1-color-olive-left-2000-top-1408.webp"
            alt=""
            width={2000}
            height={1408}
            class="not-dark:hidden max-md:hidden"
          />
        </Screenshot>
        <Screenshot class="rounded-lg max-lg:hidden" wallpaper="green" placement="bottom">
          <img
            class="dark:hidden"
            src="/img/screenshots/1.webp"
            alt=""
            width={3440}
            height={1990}
          />
          <img
            class="not-dark:hidden"
            src="/img/screenshots/1-color-olive.webp"
            alt=""
            width={3440}
            height={1990}
          />
        </Screenshot>
      </Fragment>

      <LogoGrid slot="footer">
        <Logo>
          <img
            src="/img/logos/9-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={51}
            height={32}
          />
          <img
            src="/img/logos/9-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={51}
            height={32}
          />
        </Logo>
        <Logo>
          <img
            src="/img/logos/10-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={70}
            height={32}
          />
          <img
            src="/img/logos/10-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={70}
            height={32}
          />
        </Logo>
        <Logo>
          <img
            src="/img/logos/11-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={100}
            height={32}
          />
          <img
            src="/img/logos/11-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={100}
            height={32}
          />
        </Logo>
        <Logo>
          <img
            src="/img/logos/12-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={85}
            height={32}
          />
          <img
            src="/img/logos/12-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={85}
            height={32}
          />
        </Logo>
        <Logo>
          <img
            src="/img/logos/13-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={75}
            height={32}
          />
          <img
            src="/img/logos/13-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={75}
            height={32}
          />
        </Logo>
        <Logo>
          <img
            src="/img/logos/8-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={85}
            height={32}
          />
          <img
            src="/img/logos/8-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={85}
            height={32}
          />
        </Logo>
      </LogoGrid>
    </HeroCenteredWithDemo>

    <!-- Features -->
    <FeaturesStackedAlternatingWithDemos
      id="features"
      headline="Everything you need to deliver personal, organized, and delightful support."
    >
      <p slot="subheadline">
        Work smarter, reply faster, and keep every customer conversation right where it belongs — in one simple
        inbox, where you can ignore it.
      </p>

      <Feature
        headline="Shared Inbox"
      >
        <p slot="subheadline">Manage support emails together in real time — no more support email hot potato.</p>
        <Link slot="cta" href="#">
          Learn more <ChevronIcon />
        </Link>
        <Screenshot slot="demo" wallpaper="blue" placement="bottom-right">
          <img
            src="/img/screenshots/1-left-1000-top-800.webp"
            alt=""
            class="bg-white/75 sm:hidden dark:hidden"
            width={1200}
            height={736}
          />
          <img
            src="/img/screenshots/1-color-olive-left-1000-top-800.webp"
            alt=""
            width={1200}
            height={736}
            class="bg-black/75 not-dark:hidden sm:hidden"
          />
          <img
            src="/img/screenshots/1-left-1800-top-660.webp"
            alt=""
            class="bg-white/75 max-sm:hidden lg:hidden dark:hidden"
            width={1500}
            height={680}
          />
          <img
            width={1500}
            height={680}
            src="/img/screenshots/1-color-olive-left-1800-top-660.webp"
            alt=""
            class="bg-black/75 not-dark:hidden max-sm:hidden lg:hidden"
          />
          <img
            src="/img/screenshots/1-left-1800-top-1250.webp"
            alt=""
            class="bg-white/75 max-lg:hidden dark:hidden"
            width={1500}
            height={1240}
          />
          <img
            width={1500}
            height={1240}
            src="/img/screenshots/1-color-olive-left-1800-top-1250.webp"
            alt=""
            class="bg-black/75 not-dark:hidden max-lg:hidden"
          />
        </Screenshot>
      </Feature>

      <Feature
        headline="Collision Detection"
      >
        <p slot="subheadline">See when a teammate is replying before you hit send. Goodbye duplicate replies.</p>
        <Link slot="cta" href="#">
          Learn more <ChevronIcon />
        </Link>
        <Screenshot slot="demo" wallpaper="purple" placement="top-left">
          <img
            src="/img/screenshots/1-right-1000-top-800.webp"
            alt=""
            class="bg-white/75 sm:hidden dark:hidden"
            width={1200}
            height={736}
          />
          <img
            src="/img/screenshots/1-color-olive-right-1000-top-800.webp"
            alt=""
            width={1200}
            height={736}
            class="bg-black/75 not-dark:hidden sm:hidden"
          />
          <img
            src="/img/screenshots/1-right-1800-top-660.webp"
            alt=""
            class="bg-white/75 max-sm:hidden lg:hidden dark:hidden"
            width={1500}
            height={680}
          />
          <img
            src="/img/screenshots/1-color-olive-right-1800-top-660.webp"
            alt=""
            width={1500}
            height={680}
            class="bg-black/75 not-dark:hidden max-sm:hidden lg:hidden"
          />
          <img
            src="/img/screenshots/1-right-1800-top-1250.webp"
            alt=""
            class="bg-white/75 max-lg:hidden dark:hidden"
            width={1500}
            height={1240}
          />
          <img
            src="/img/screenshots/1-color-olive-right-1800-top-1250.webp"
            width={1500}
            height={1240}
            alt=""
            class="bg-black/75 not-dark:hidden max-lg:hidden"
          />
        </Screenshot>
      </Feature>

      <Feature
        headline="Inbox Agent"
      >
        <p slot="subheadline">Get valuable context without having to read through a long thread.</p>
        <Link slot="cta" href="#">
          Learn more <ChevronIcon />
        </Link>
        <Screenshot slot="demo" wallpaper="brown" placement="bottom-left">
          <img
            src="/img/screenshots/1-right-1000-top-800.webp"
            alt=""
            class="bg-white/75 sm:hidden dark:hidden"
            width={1200}
            height={736}
          />
          <img
            src="/img/screenshots/1-color-olive-right-1000-top-800.webp"
            alt=""
            width={1200}
            height={736}
            class="bg-black/75 not-dark:hidden sm:hidden"
          />
          <img
            src="/img/screenshots/1-right-1800-top-660.webp"
            alt=""
            class="bg-white/75 max-sm:hidden lg:hidden dark:hidden"
            width={1500}
            height={680}
          />
          <img
            src="/img/screenshots/1-color-olive-right-1800-top-660.webp"
            alt=""
            width={1500}
            height={680}
            class="bg-black/75 not-dark:hidden max-sm:hidden lg:hidden"
          />
          <img
            src="/img/screenshots/1-right-1800-top-1250.webp"
            alt=""
            class="bg-white/75 max-lg:hidden dark:hidden"
            width={1500}
            height={1240}
          />
          <img
            src="/img/screenshots/1-color-olive-right-1800-top-1250.webp"
            alt=""
            width={1500}
            height={1240}
            class="bg-black/75 not-dark:hidden max-lg:hidden"
          />
        </Screenshot>
      </Feature>
    </FeaturesStackedAlternatingWithDemos>

    <!-- Brands -->
    <BrandsCardsMultiColumn
      id="brands"
      eyebrow="Backed by the best"
      headline="Funded by leading investors."
    >
      <p slot="subheadline">
        Oatmeal is backed by investors with decades of experience building the world's most boring and predictable
        B2B SaaS.
      </p>

      <BrandCard>
        <Fragment slot="logo">
          <img
            src="/img/logos/12-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={124}
            height={32}
          />
          <img
            src="/img/logos/12-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={124}
            height={32}
          />
        </Fragment>
        <p slot="text">Focused capital for founders building the next generation of pyramid shaped businesses.</p>
        <span slot="footnote">Investor in Anomaly, Concise, Haptic and more.</span>
      </BrandCard>

      <BrandCard>
        <Fragment slot="logo">
          <img
            src="/img/logos/13-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={146}
            height={32}
          />
          <img
            src="/img/logos/13-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={146}
            height={32}
          />
        </Fragment>
        <p slot="text">Serving as a tax-efficiency vehicle for investors waiting to move to a tax haven.</p>
        <span slot="footnote">Investor in Quirk, Looply, Pine Labs and more.</span>
      </BrandCard>

      <BrandCard>
        <Fragment slot="logo">
          <img
            src="/img/logos/11-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={106}
            height={32}
          />
          <img
            src="/img/logos/11-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={106}
            height={32}
          />
        </Fragment>
        <p slot="text">Investing in potentially volatile bubble markets at an early stage.</p>
        <span slot="footnote">Investor in Artifact, Umbra, vivid.ai and more.</span>
      </BrandCard>
    </BrandsCardsMultiColumn>

    <!-- Testimonial -->
    <TestimonialTwoColumnWithLargePhoto
      id="testimonial"
      name="Lynn Marshall"
      byline="Founder at Pine Labs"
    >
      <p slot="quote">
        Ever since we started using Oatmeal, our customer satisfaction scores have skyrocketed. The personal touch
        that their human-AI hybrid support provides is unparalleled.
      </p>
      <img
        slot="img"
        src="/img/avatars/16-h-1000-w-1400.webp"
        alt=""
        class="not-dark:bg-white/75 dark:bg-black/75"
        width={1400}
        height={1000}
      />
    </TestimonialTwoColumnWithLargePhoto>

    <!-- Stats -->
    <StatsWithGraph
      id="stats"
      eyebrow="Built for scale"
      headline="The inbox powering customer conversations everywhere."
    >
      <p slot="subheadline">
        Oatmeal helps teams deliver personal, organized, and fast customer support across the world. From small
        startups to enterprise teams, we process millions of messages each month — using a massive network of low
        wage workers stationed around the globe.
      </p>
      <Stat stat="2M+" text="Emails manually processed every week across thousands of teams." />
      <Stat stat="99.98%" text="Uptime — because your customers never stop complaining." />
    </StatsWithGraph>

    <!-- Call To Action -->
    <CallToActionSimple
      id="call-to-action"
      headline="Ready to make customer support feel simple again?"
    >
      <p slot="subheadline">
        Join hundreds of teams using Oatmeal to deliver faster, friendlier email support — using a massive network
        of low wage workers stationed around the globe
      </p>
      <div slot="cta" class="flex items-center gap-4">
        <ButtonLink href="#" size="lg">
          Start free trial
        </ButtonLink>

        <PlainButtonLink href="#" size="lg">
          Book a demo <ChevronIcon />
        </PlainButtonLink>
      </div>
    </CallToActionSimple>
  </Main>

  <FooterWithLinksAndSocialIcons
    id="footer"
    fineprint="© 2025 Oatmeal, Inc."
  >
    <Fragment slot="links">
      <FooterLink href="#">About</FooterLink>
      <FooterLink href="#">Careers</FooterLink>
      <FooterLink href="#">Blog</FooterLink>
      <FooterLink href="#">Help Center</FooterLink>
      <FooterLink href="#">Press Kit</FooterLink>
      <FooterLink href="#">Privacy Policy</FooterLink>
    </Fragment>
    <Fragment slot="socialLinks">
      <SocialLink href="https://x.com" name="X">
        <XIcon />
      </SocialLink>
      <SocialLink href="https://github.com" name="GitHub">
        <GitHubIcon />
      </SocialLink>
      <SocialLink href="https://www.youtube.com" name="YouTube">
        <YouTubeIcon />
      </SocialLink>
    </Fragment>
  </FooterWithLinksAndSocialIcons>
</Base>
