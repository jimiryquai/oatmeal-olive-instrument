---
import { Icon } from "astro-iconset/components";
import { getEmDashEntry } from "emdash";
import Base from "../layouts/Base.astro";
import MarketingBlocks from "../components/MarketingBlocks.astro";

const { entry: page, cacheHint } = await getEmDashEntry("pages", "contact");

// `cache.set` only applies to GET responses; wrap defensively because
// this route also handles POST submissions where the cache API may
// reject the call.
try {
	Astro.cache.set(cacheHint);
} catch {}

// Handle form submission
let formStatus: "idle" | "success" | "error" = "idle";
let formMessage = "";

if (Astro.request.method === "POST") {
	try {
		const formData = await Astro.request.formData();
		const name = formData.get("name")?.toString() || "";
		const email = formData.get("email")?.toString() || "";
		const company = formData.get("company")?.toString() || "";
		const message = formData.get("message")?.toString() || "";

		if (!name || !email || !message) {
			formStatus = "error";
			formMessage = "Please fill in all required fields.";
		} else if (!email.includes("@")) {
			formStatus = "error";
			formMessage = "Please enter a valid email address.";
		} else {
			// TODO: Replace with actual email/webhook integration
			console.log("Contact form submission:", {
				name,
				email,
				company,
				message,
			});
			formStatus = "success";
			formMessage =
				"Thanks for reaching out! We'll get back to you within 24 hours.";
		}
	} catch {
		formStatus = "error";
		formMessage = "Something went wrong. Please try again.";
	}
}

const pageContent = page?.data.content;
---

<Base
	title="Contact"
	description="Have questions? Want a demo? We'd love to hear from you."
>
	{pageContent && <MarketingBlocks value={pageContent} />}

	<section class="py-16 md:py-24 font-sans bg-olive-100 dark:bg-olive-950">
		<div class="mx-auto max-w-7xl px-6 lg:px-10">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
				
				{/* Left Side: Contact Information */}
				<div class="lg:col-span-5 space-y-8">
					<div class="space-y-4">
						<h2 class="text-3xl sm:text-4xl font-display font-semibold tracking-tight text-olive-950 dark:text-white leading-tight">
							Talk to our team
						</h2>
						<p class="text-base sm:text-lg text-olive-700 dark:text-olive-350">
							Fill out the form and we'll be in touch within 24 hours.
						</p>
					</div>

					<div class="space-y-6">
						<div class="flex items-center gap-4">
							<div class="w-12 h-12 flex items-center justify-center text-xl text-white bg-olive-900 dark:bg-white dark:text-olive-950 border border-olive-950/5 dark:border-white/5 rounded-2xl flex-shrink-0 shadow-sm">
								<Icon name="ph:envelope" class="w-6 h-6" aria-hidden="true" />
							</div>
							<div class="space-y-0.5">
								<h4 class="text-xs font-semibold tracking-widest uppercase text-olive-500 dark:text-olive-400">Email</h4>
								<a href="mailto:hello@acme.example" class="text-base font-medium text-olive-900 dark:text-white hover:underline underline-offset-4 decoration-1">
									hello@acme.example
								</a>
							</div>
						</div>
						
						<div class="flex items-center gap-4">
							<div class="w-12 h-12 flex items-center justify-center text-xl text-white bg-olive-900 dark:bg-white dark:text-olive-950 border border-olive-950/5 dark:border-white/5 rounded-2xl flex-shrink-0 shadow-sm">
								<Icon name="ph:lifebuoy" class="w-6 h-6" aria-hidden="true" />
							</div>
							<div class="space-y-0.5">
								<h4 class="text-xs font-semibold tracking-widest uppercase text-olive-500 dark:text-olive-400">Support</h4>
								<a href="mailto:support@acme.example" class="text-base font-medium text-olive-900 dark:text-white hover:underline underline-offset-4 decoration-1">
									support@acme.example
								</a>
							</div>
						</div>

						<div class="flex items-center gap-4">
							<div class="w-12 h-12 flex items-center justify-center text-xl text-white bg-olive-900 dark:bg-white dark:text-olive-950 border border-olive-950/5 dark:border-white/5 rounded-2xl flex-shrink-0 shadow-sm">
								<Icon name="ph:currency-dollar" class="w-6 h-6" aria-hidden="true" />
							</div>
							<div class="space-y-0.5">
								<h4 class="text-xs font-semibold tracking-widest uppercase text-olive-500 dark:text-olive-400">Sales</h4>
								<a href="mailto:sales@acme.example" class="text-base font-medium text-olive-900 dark:text-white hover:underline underline-offset-4 decoration-1">
									sales@acme.example
								</a>
							</div>
						</div>
					</div>
				</div>

				{/* Right Side: Contact Form Container */}
				<div class="lg:col-span-7 bg-olive-950/2.5 dark:bg-white/2.5 border border-olive-950/5 dark:border-white/5 rounded-3xl p-6 sm:p-8 shadow-sm">
					{
						formStatus === "success" ? (
							<div class="text-center py-8 space-y-6">
								<div class="w-16 h-16 flex items-center justify-center text-2xl text-white bg-olive-900 dark:bg-white dark:text-olive-950 rounded-full mx-auto shadow-sm">
									✓
								</div>
								<div class="space-y-2">
									<h3 class="text-2xl font-display font-semibold text-olive-950 dark:text-white">Message Sent!</h3>
									<p class="text-olive-600 dark:text-olive-400 max-w-sm mx-auto">{formMessage}</p>
								</div>
								<a 
									href="/contact" 
									class="inline-flex items-center justify-center px-6 py-2.5 rounded-full text-sm font-semibold text-white bg-olive-900 hover:bg-olive-800 dark:bg-white dark:text-olive-950 dark:hover:bg-olive-100 transition duration-150 shadow-sm"
								>
									Send another message
								</a>
							</div>
						) : (
							<form method="POST" class="space-y-6">
								{formStatus === "error" && (
									<div class="p-4 bg-red-500/10 border border-red-500/25 rounded-2xl text-red-600 dark:text-red-400 text-sm">
										<p>{formMessage}</p>
									</div>
								)}

								<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
									<div class="flex flex-col gap-2">
										<label for="name" class="text-sm font-medium text-olive-950 dark:text-white">Name *</label>
										<input
											type="text"
											id="name"
											name="name"
											required
											placeholder="Your name"
											autocomplete="name"
											class="w-full px-4 py-3 bg-olive-100 dark:bg-olive-950 border border-olive-950/10 dark:border-white/10 rounded-2xl text-olive-950 dark:text-white placeholder:text-olive-400 dark:placeholder:text-olive-600 focus:outline-none focus:border-olive-900 dark:focus:border-white transition-colors duration-150"
										/>
									</div>
									<div class="flex flex-col gap-2">
										<label for="email" class="text-sm font-medium text-olive-950 dark:text-white">Email *</label>
										<input
											type="email"
											id="email"
											name="email"
											required
											placeholder="you@company.com"
											autocomplete="email"
											class="w-full px-4 py-3 bg-olive-100 dark:bg-olive-950 border border-olive-950/10 dark:border-white/10 rounded-2xl text-olive-950 dark:text-white placeholder:text-olive-400 dark:placeholder:text-olive-600 focus:outline-none focus:border-olive-900 dark:focus:border-white transition-colors duration-150"
										/>
									</div>
								</div>

								<div class="flex flex-col gap-2">
									<label for="company" class="text-sm font-medium text-olive-950 dark:text-white">Company</label>
									<input
										type="text"
										id="company"
										name="company"
										placeholder="Your company"
										autocomplete="organization"
										class="w-full px-4 py-3 bg-olive-100 dark:bg-olive-950 border border-olive-950/10 dark:border-white/10 rounded-2xl text-olive-950 dark:text-white placeholder:text-olive-400 dark:placeholder:text-olive-600 focus:outline-none focus:border-olive-900 dark:focus:border-white transition-colors duration-150"
									/>
								</div>

								<div class="flex flex-col gap-2">
									<label for="message" class="text-sm font-medium text-olive-950 dark:text-white">Message *</label>
									<textarea
										id="message"
										name="message"
										required
										rows="5"
										placeholder="Tell us about your project or question..."
										class="w-full px-4 py-3 bg-olive-100 dark:bg-olive-950 border border-olive-950/10 dark:border-white/10 rounded-2xl text-olive-950 dark:text-white placeholder:text-olive-400 dark:placeholder:text-olive-600 focus:outline-none focus:border-olive-900 dark:focus:border-white transition-colors duration-150 resize-y min-h-[120px]"
									/>
								</div>

								<button 
									type="submit" 
									class="inline-flex items-center justify-center px-6 py-3 rounded-full text-base font-semibold text-white bg-olive-900 hover:bg-olive-800 dark:bg-white dark:text-olive-950 dark:hover:bg-olive-100 transition duration-150 cursor-pointer shadow-sm"
								>
									Send Message
								</button>
							</form>
						)
					}
				</div>

			</div>
		</div>
	</section>
</Base>
