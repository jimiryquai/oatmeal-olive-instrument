# CORS and Cache-Control for Agent Discovery Endpoints
/.well-known/*
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=300

# CORS and Cache-Control for Schema Endpoints
/schema/*
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=300

/schemamap.xml
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=300

/sitemap.xml
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600

# Immutable static assets
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Strip marketing parameters to prevent cache fragmentation
/*
  No-Vary-Search: params=(utm_source utm_medium utm_campaign utm_term utm_content gclid fbclid)
