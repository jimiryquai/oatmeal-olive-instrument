---
import Base from '../layouts/Base.astro'
import ButtonLink from '@jamesryan/ui/components/elements/ButtonLink.astro'
import PlainButtonLink from '@jamesryan/ui/components/elements/PlainButtonLink.astro'
import SoftButtonLink from '@jamesryan/ui/components/elements/SoftButtonLink.astro'
import LogoGrid from '@jamesryan/ui/components/elements/logo-grid.astro'
import Logo from '@jamesryan/ui/components/elements/logo.astro'
import Main from '@jamesryan/ui/components/elements/main.astro'
import ChevronIcon from '@jamesryan/ui/components/icons/chevron-icon.astro'
import GitHubIcon from '@jamesryan/ui/components/icons/social/github-icon.astro'
import XIcon from '@jamesryan/ui/components/icons/social/x-icon.astro'
import YouTubeIcon from '@jamesryan/ui/components/icons/social/youtube-icon.astro'
import CallToActionSimpleCentered from '@jamesryan/ui/components/sections/CallToActionSimpleCentered.astro'
import FAQsAccordion from '@jamesryan/ui/components/sections/FAQsAccordion.astro'
import Faq from '@jamesryan/ui/components/sections/Faq.astro'
import FooterCategory from '@jamesryan/ui/components/sections/FooterCategory.astro'
import FooterLink from '@jamesryan/ui/components/sections/FooterLink.astro'
import FooterWithNewsletterFormCategoriesAndSocialIcons from '@jamesryan/ui/components/sections/FooterWithNewsletterFormCategoriesAndSocialIcons.astro'
import NewsletterForm from '@jamesryan/ui/components/sections/NewsletterForm.astro'
import SocialLink from '@jamesryan/ui/components/sections/SocialLink.astro'
import NavbarLink from '@jamesryan/ui/components/sections/NavbarLink.astro'
import NavbarLogo from '@jamesryan/ui/components/sections/NavbarLogo.astro'
import NavbarWithLinksActionsAndCenteredLogo from '@jamesryan/ui/components/sections/NavbarWithLinksActionsAndCenteredLogo.astro'
import PlanComparisonTable from '@jamesryan/ui/components/sections/PlanComparisonTable.astro'
import PricingHeroMultiTier from '@jamesryan/ui/components/sections/PricingHeroMultiTier.astro'
import PricingPlan from '@jamesryan/ui/components/sections/PricingPlan.astro'
import TestimonialTwoColumnWithLargePhoto from '@jamesryan/ui/components/sections/TestimonialTwoColumnWithLargePhoto.astro'
---

<Base hideHeaderFooter={true} title="Pricing" description="Simple, transparent pricing. No hidden fees. No surprises.">
  <NavbarWithLinksActionsAndCenteredLogo id="navbar">
    <Fragment slot="links">
      <NavbarLink href="#">Pricing</NavbarLink>
      <NavbarLink href="#">About</NavbarLink>
      <NavbarLink href="#">Docs</NavbarLink>
      <NavbarLink href="/_emdash/admin" class="sm:hidden">Log in</NavbarLink>
    </Fragment>
    <NavbarLogo slot="logo" href="#">
      <img
        src="/img/logos/oatmeal-instrument-color-olive-950.svg"
        alt="Oatmeal"
        class="dark:hidden"
        width={85}
        height={28}
      />
      <img
        src="/img/logos/oatmeal-instrument-color-white.svg"
        alt="Oatmeal"
        class="not-dark:hidden"
        width={85}
        height={28}
      />
    </NavbarLogo>
    <Fragment slot="actions">
      <PlainButtonLink href="/_emdash/admin" class="max-sm:hidden">Log in</PlainButtonLink>
      <ButtonLink href="#">Get started</ButtonLink>
    </Fragment>
  </NavbarWithLinksActionsAndCenteredLogo>

  <Main>
    <!-- Hero -->
    <PricingHeroMultiTier
      id="pricing"
      headline="Pricing"
    >
      <p slot="subheadline">
        Simplify your shared inbox, collaborate effortlessly, and give every customer a reply that feels personal,
        even if it was written by a bot.
      </p>

      <Fragment slot="monthly-plans">
        <PricingPlan
          name="Starter"
          price="$12"
          period="/month"
          features={[
            'Shared inbox for up to 2 mailboxes',
            'Tagging & assignment',
            'Private notes',
            'Automatic replies',
            'Email support',
          ]}
        >
          <p slot="subheadline">Small teams getting started with shared inboxes</p>
          <SoftButtonLink slot="cta" href="#" size="lg">
            Start free trial
          </SoftButtonLink>
        </PricingPlan>
        <PricingPlan
          name="Growth"
          price="$49"
          period="/month"
          badge="Most popular"
          features={[
            'Everything in Starter',
            'Inbox Agent',
            'Unlimited mailboxes',
            'Collision detection',
            'Snippets and templates',
            'Reporting dashboard',
            'Slack integration',
          ]}
        >
          <p slot="subheadline">Growing teams needing collaboration and insights</p>
          <ButtonLink slot="cta" href="#" size="lg">
            Start free trial
          </ButtonLink>
        </PricingPlan>
        <PricingPlan
          name="Pro"
          price="$299"
          period="/month"
          features={[
            'Everything in Growth',
            'Custom roles & permissions',
            'Automation engine',
            'API access',
            'SLA tracking',
            'SSO support',
            'SOC 2 compliance',
          ]}
        >
          <p slot="subheadline">Support-focused organizations and larger teams</p>
          <SoftButtonLink slot="cta" href="#" size="lg">
            Start free trial
          </SoftButtonLink>
        </PricingPlan>
      </Fragment>

      <Fragment slot="yearly-plans">
        <PricingPlan
          name="Starter"
          price="$120"
          period="/year"
          features={[
            'Shared inbox for up to 2 mailboxes',
            'Tagging & assignment',
            'Private notes',
            'Automatic replies',
            'Email support',
          ]}
        >
          <p slot="subheadline">Small teams getting started with shared inboxes</p>
          <SoftButtonLink slot="cta" href="#" size="lg">
            Start free trial
          </SoftButtonLink>
        </PricingPlan>
        <PricingPlan
          name="Growth"
          price="$490"
          period="/year"
          badge="Most popular"
          features={[
            'Everything in Starter',
            'Inbox Agent',
            'Unlimited mailboxes',
            'Collision detection',
            'Snippets and templates',
            'Reporting dashboard',
            'Slack integration',
          ]}
        >
          <p slot="subheadline">Growing teams needing collaboration and insights</p>
          <ButtonLink slot="cta" href="#" size="lg">
            Start free trial
          </ButtonLink>
        </PricingPlan>
        <PricingPlan
          name="Pro"
          price="$2990"
          period="/year"
          features={[
            'Everything in Growth',
            'Custom roles & permissions',
            'Automation engine',
            'API access',
            'SLA tracking',
            'SSO support',
            'SOC 2 compliance',
          ]}
        >
          <p slot="subheadline">Support-focused organizations and larger teams</p>
          <SoftButtonLink slot="cta" href="#" size="lg">
            Start free trial
          </SoftButtonLink>
        </PricingPlan>
      </Fragment>

      <LogoGrid slot="footer">
        <Logo>
          <img
            src="/img/logos/9-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={51}
            height={32}
          />
          <img
            src="/img/logos/9-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={51}
            height={32}
          />
        </Logo>
        <Logo>
          <img
            src="/img/logos/10-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={70}
            height={32}
          />
          <img
            src="/img/logos/10-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={70}
            height={32}
          />
        </Logo>
        <Logo>
          <img
            src="/img/logos/11-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={100}
            height={32}
          />
          <img
            src="/img/logos/11-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={100}
            height={32}
          />
        </Logo>
        <Logo>
          <img
            src="/img/logos/12-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={85}
            height={32}
          />
          <img
            src="/img/logos/12-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={85}
            height={32}
          />
        </Logo>
        <Logo>
          <img
            src="/img/logos/13-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={75}
            height={32}
          />
          <img
            src="/img/logos/13-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={75}
            height={32}
          />
        </Logo>
        <Logo>
          <img
            src="/img/logos/8-color-black-height-32.svg"
            class="dark:hidden"
            alt=""
            width={85}
            height={32}
          />
          <img
            src="/img/logos/8-color-white-height-32.svg"
            class="not-dark:hidden"
            alt=""
            width={85}
            height={32}
          />
        </Logo>
      </LogoGrid>
    </PricingHeroMultiTier>

    <!-- Plan Comparison Table -->
    <PlanComparisonTable
      id="pricing"
      plans={['Starter', 'Growth', 'Pro']}
      features={[
        {
          title: 'Collaboration',
          features: [
            {
              name: 'Shared inboxes',
              value: { Starter: '2', Growth: 'Unlimited', Pro: 'Unlimited' },
            },
            { name: 'Private notes', value: true },
            { name: 'Tagging & assignment', value: true },
            {
              name: 'Collision detection',
              value: { Starter: false, Growth: true, Pro: true },
            },
            {
              name: 'Real-time activity indicators',
              value: { Starter: false, Growth: true, Pro: true },
            },
            {
              name: 'Internal chat',
              value: { Starter: false, Growth: true, Pro: true },
            },
          ],
        },
        {
          title: 'Automation',
          features: [
            { name: 'Automatic replies', value: true },
            {
              name: 'Inbox Agent',
              value: { Starter: false, Growth: true, Pro: true },
            },
            {
              name: 'Automation engine',
              value: { Starter: false, Growth: true, Pro: true },
            },
            {
              name: 'Snippets and templates',
              value: { Starter: false, Growth: true, Pro: true },
            },
            {
              name: 'SLA tracking',
              value: { Starter: false, Growth: false, Pro: true },
            },
          ],
        },
        {
          title: 'Team Management',
          features: [
            {
              name: 'Unlimited users',
              value: { Starter: 'Up to 5', Growth: true, Pro: true },
            },
            {
              name: 'Reporting dashboard',
              value: { Starter: false, Growth: true, Pro: true },
            },
            {
              name: 'Slack integration',
              value: { Starter: false, Growth: true, Pro: true },
            },
            {
              name: 'Roles & permissions',
              value: { Starter: false, Growth: false, Pro: true },
            },
            {
              name: 'SSO support',
              value: { Starter: false, Growth: false, Pro: true },
            },
          ],
        },
        {
          title: 'Support',
          features: [
            { name: 'Email support', value: true },
            {
              name: 'Priority response',
              value: { Starter: false, Growth: true, Pro: true },
            },
            {
              name: 'Dedicated manager',
              value: { Starter: false, Growth: false, Pro: true },
            },
          ],
        },
      ]}
    />

    <!-- Testimonial -->
    <TestimonialTwoColumnWithLargePhoto
      id="testimonial"
      name="Lynn Marshall"
      byline="Founder at Pine Labs"
    >
      <p slot="quote">
        Ever since we started using Oatmeal, our customer satisfaction scores have skyrocketed. The personal touch
        that their human-AI hybrid support provides is unparalleled.
      </p>
      <img
        slot="img"
        src="/img/avatars/16-h-1000-w-1400.webp"
        alt=""
        class="not-dark:bg-white/75 dark:bg-black/75"
        width={1400}
        height={1000}
      />
    </TestimonialTwoColumnWithLargePhoto>

    <!-- FAQs -->
    <FAQsAccordion id="faqs" headline="Questions & Answers">
      <Faq
        id="faq-1"
        question="Do I need a credit card to start the free trial?"
        answer="Yes, but don't worry, you won't be charged until the trial period is over. We won't send you an email reminding you when this happens because we are really hoping you'll forget and we can keep charging you until your cards expires"
      />
      <Faq
        id="faq-2"
        question="Can my whole team use the same inbox?"
        answer="Yes, the more the merrier! Oatmeal works best when your entire company has access. We will charge you per additional seat, but we won't tell you about this until you get your invoice."
      />
      <Faq
        id="faq-3"
        question="Is the AI agent actually a bunch of people in India?"
        answer="Not just India! We have people in lots of countries around the world pretending to be an AI, including some that are currently under sanctions, so we can't legally mention them here."
      />
      <Faq
        id="faq-4"
        question="Does Oatmeal replace my email client?"
        answer="Absolutely. The idea is that we transition you away from email entirely, so you become completely dependent on our service. Like a parasite living off a host."
      />
    </FAQsAccordion>

    <!-- Call To Action -->
    <CallToActionSimpleCentered
      id="call-to-action"
      headline="Have anymore questions?"
    >
      <p slot="subheadline">Chat to someone on our sales team, who will make promises about our roadmap that we won't keep.</p>
      <div slot="cta" class="flex items-center gap-4">
        <ButtonLink href="#" size="lg">
          Chat with us
        </ButtonLink>

        <PlainButtonLink href="#" size="lg">
          Book a demo <ChevronIcon />
        </PlainButtonLink>
      </div>
    </CallToActionSimpleCentered>
  </Main>

  <FooterWithNewsletterFormCategoriesAndSocialIcons id="footer">
    <NewsletterForm
      slot="cta"
      headline="Stay in the loop"
      action="#"
    >
      <p slot="subheadline">
        Get customer support tips, product updates and customer stories that you can archive as soon as they
        arrive.
      </p>
    </NewsletterForm>
    <Fragment slot="links">
      <FooterCategory title="Product">
        <FooterLink href="#">Features</FooterLink>
        <FooterLink href="#">Pricing</FooterLink>
        <FooterLink href="#">Integrations</FooterLink>
      </FooterCategory>
      <FooterCategory title="Company">
        <FooterLink href="#">About</FooterLink>
        <FooterLink href="#">Careers</FooterLink>
        <FooterLink href="#">Blog</FooterLink>
        <FooterLink href="#">Press Kit</FooterLink>
      </FooterCategory>
      <FooterCategory title="Resources">
        <FooterLink href="#">Help Center</FooterLink>
        <FooterLink href="#">API Docs</FooterLink>
        <FooterLink href="#">Status</FooterLink>
        <FooterLink href="#">Contact</FooterLink>
      </FooterCategory>
      <FooterCategory title="Legal">
        <FooterLink href="#">Privacy Policy</FooterLink>
        <FooterLink href="#">Terms of Service</FooterLink>
        <FooterLink href="#">Security</FooterLink>
      </FooterCategory>
    </Fragment>
    <Fragment slot="socialLinks">
      <SocialLink href="https://x.com" name="X">
        <XIcon />
      </SocialLink>
      <SocialLink href="https://github.com" name="GitHub">
        <GitHubIcon />
      </SocialLink>
      <SocialLink href="https://www.youtube.com" name="YouTube">
        <YouTubeIcon />
      </SocialLink>
    </Fragment>
    <span slot="fineprint">© 2025 Oatmeal, Inc.</span>
  </FooterWithNewsletterFormCategoriesAndSocialIcons>
</Base>
