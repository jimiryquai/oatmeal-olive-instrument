---
export const prerender = false;

import {
	getEmDashCollection,
	getTaxonomyTerms,
	getTermsForEntries,
} from "emdash";
import Base from "../../layouts/Base.astro";
import ProjectCard from "@jamesryan/ui/components/ProjectCard.astro";

const activeTag = Astro.url.searchParams.get("tag");

const [{ entries: sortedProjects, cacheHint }, tags] = await Promise.all([
	getEmDashCollection("projects", {
		orderBy: { published_at: "desc" },
		...(activeTag ? { where: { tag: activeTag } } : {}),
	}),
	getTaxonomyTerms("tag"),
]);

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

// Batched retrieval of tags for the cards
const tagsByEntry = await getTermsForEntries(
	"projects",
	sortedProjects.map((p) => p.data.id),
	"tag",
);

const projectsWithTags = sortedProjects.map((project) => ({
	project,
	projectTags: (tagsByEntry.get(project.data.id) ?? []).map((t) => ({
		slug: t.slug,
		label: t.label,
	})),
}));
---

<Base 
	title={activeTag
		? `${tags.find((t) => t.slug === activeTag)?.label || activeTag} — Work`
		: "Work"}
	description="A selection of creative projects spanning branding, web design, and development from the Oatmeal team."
>
	<div class="mx-auto w-full max-w-7xl px-6 lg:px-10 py-16 sm:py-24">
		<header class="mb-12 border-b border-olive-950/10 dark:border-white/10 pb-8">
			<span class="block text-xs font-semibold tracking-widest uppercase text-olive-600 dark:text-olive-400 mb-2">Our Portfolio</span>
			<h1 class="text-4xl sm:text-5xl font-display tracking-tight text-olive-950 dark:text-white">
				Selected Work
			</h1>
			<p class="mt-2 text-base text-olive-600 dark:text-olive-400">
				Discover projects spanning brand identity, design systems, and custom development.
			</p>
		</header>

		{
			tags.length > 0 && (
				<nav class="flex flex-wrap gap-2 mb-10" aria-label="Filter by tag">
					<a
						href="/work"
						class={`inline-block px-4 py-1.5 text-sm rounded-full transition-colors duration-150 ${
							!activeTag
								? "bg-olive-950 text-white dark:bg-white dark:text-olive-950 font-medium"
								: "bg-olive-950/2.5 hover:bg-olive-950/5 text-olive-800 dark:bg-white/5 dark:hover:bg-white/10 dark:text-olive-300"
						}`}
					>
						All Work
					</a>
					{tags.map((tag) => (
						<a
							href={`/work?tag=${tag.slug}`}
							class={`inline-block px-4 py-1.5 text-sm rounded-full transition-colors duration-150 ${
								activeTag === tag.slug
									? "bg-olive-950 text-white dark:bg-white dark:text-olive-950 font-medium"
									: "bg-olive-950/2.5 hover:bg-olive-950/5 text-olive-800 dark:bg-white/5 dark:hover:bg-white/10 dark:text-olive-300"
							}`}
						>
							{tag.label}
						</a>
					))}
				</nav>
			)
		}

		{
			projectsWithTags.length === 0 ? (
				<p class="text-lg text-olive-650 dark:text-olive-455">No projects found.</p>
			) : (
				<div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-16">
					{projectsWithTags.map(({ project, projectTags }) => (
						<ProjectCard
							title={project.data.title ?? "Untitled"}
							summary={project.data.summary}
							featuredImage={project.data.featured_image}
							href={`/work/${project.id}`}
							client={project.data.client}
							year={project.data.year}
							tags={projectTags}
						/>
					))}
				</div>
			)
		}
	</div>
</Base>
