---
import {
	getEmDashEntry,
	getEmDashCollection,
	getEntryTerms,
	getTermsForEntries,
	getSeoMeta,
	decodeSlug,
	getSiteSettings,
} from "emdash";
import {
	Image,
	PortableText,
	Comments,
	CommentForm,
	WidgetArea,
} from "emdash/ui";
import Base from "../../layouts/Base.astro";
import PostCard from "@jamesryan/ui/components/PostCard.astro";
import { getReadingTime } from "@jamesryan/cms-helpers";
import { resolveBlogSiteIdentity } from "../../utils/site-identity";
import { blockComponents } from "emdash-plugin-code-block-pro/astro";

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);

if (!post) {
	return Astro.redirect("/404");
}

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

// Get featured image URL for OG fallback
function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	if (typeof image.src === "string" && image.src) {
		return image.src.startsWith("http")
			? image.src
			: `${Astro.url.origin}${image.src}`;
	}
	const meta = image.meta as Record<string, unknown> | undefined;
	const storageKey =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);
	if (storageKey) {
		return `${Astro.url.origin}/_emdash/api/media/file/${storageKey}`;
	}
	return undefined;
}
const featuredImageUrl = getImageUrl(post.data.featured_image);
const { siteTitle } = resolveBlogSiteIdentity(await getSiteSettings());

// Generate SEO meta from content
const seo = getSeoMeta(post, {
	siteTitle,
	siteUrl: Astro.url.origin,
	path: `/posts/${slug}`,
	defaultOgImage: featuredImageUrl,
});

const bylines = post.data.bylines ?? [];
const readingTime = getReadingTime(post.data.content);

const [tags, { entries: recentPosts }] = await Promise.all([
	getEntryTerms("posts", post.data.id, "tag"),
	getEmDashCollection("posts", {
		orderBy: { published_at: "desc" },
		limit: 4,
	}),
]);
const otherPosts = recentPosts.filter((p) => p.id !== post.id).slice(0, 3);

const otherTagsByEntry = await getTermsForEntries(
	"posts",
	otherPosts.map((p) => p.data.id),
	"tag",
);
const otherPostsWithTags = otherPosts.map((p) => ({
	post: p,
	tags: otherTagsByEntry.get(p.data.id) ?? [],
	bylines: p.data.bylines ?? [],
}));

const publishDate =
	post.data.publishedAt?.toLocaleDateString("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	}) ?? null;
---

<Base
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description ?? undefined}
	image={seo.ogImage ?? undefined}
	canonical={seo.canonical}
	robots={seo.robots}
	type="article"
	publishedTime={post.data.publishedAt?.toISOString() ?? null}
	modifiedTime={post.data.updatedAt.toISOString()}
	content={{ collection: "posts", id: post.data.id, slug }}
>
	<article class="mx-auto w-full max-w-7xl px-6 lg:px-10 py-16">
		{/* Hero: Full-width featured image */}
		{
			post.data.featured_image && (
				<div class="mb-12 rounded-3xl overflow-hidden bg-olive-950/2.5 dark:bg-white/5 border border-olive-950/5 dark:border-white/5 max-h-[500px]" {...post.edit.featured_image}>
					<Image image={post.data.featured_image} class="w-full h-full object-cover" />
				</div>
			)
		}

		{/* Three-column layout */}
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
			{/* Left Column: Meta (Desktop-only sidebar) */}
			<aside class="lg:col-span-3 lg:block hidden sticky top-28 self-start">
				<div class="space-y-8">
					{
						bylines.length > 0 && (
							<div class="space-y-3">
								<span class="block text-xs font-semibold tracking-widest uppercase text-olive-500 dark:text-olive-400">
									{bylines.length === 1 ? "Author" : "Authors"}
								</span>
								<div class="space-y-4">
									{bylines.map((credit) => (
										<div class="flex items-center gap-3">
											{credit.byline.avatarMediaId && (
												<img
													src={`/_emdash/api/media/file/${credit.byline.avatarMediaId}`}
													alt={credit.byline.displayName}
													class="w-10 h-10 rounded-full object-cover border border-olive-950/5 dark:border-white/10"
												/>
											)}
											<div class="flex flex-col min-w-0">
												<span class="text-sm font-semibold text-olive-950 dark:text-white truncate">
													{credit.byline.displayName}
												</span>
												{credit.roleLabel && (
													<span class="text-xs text-olive-550 dark:text-olive-400 truncate">{credit.roleLabel}</span>
												)}
											</div>
										</div>
									))}
								</div>
							</div>
						)
					}
					{
						publishDate && (
							<div class="space-y-1">
								<span class="block text-xs font-semibold tracking-widest uppercase text-olive-500 dark:text-olive-400">Published</span>
								<time class="block text-sm text-olive-755 dark:text-olive-350 font-medium">{publishDate}</time>
							</div>
						)
					}
					<div class="space-y-1">
						<span class="block text-xs font-semibold tracking-widest uppercase text-olive-500 dark:text-olive-400">Reading time</span>
						<span class="block text-sm text-olive-755 dark:text-olive-350 font-medium">{readingTime} min read</span>
					</div>
					{
						tags.length > 0 && (
							<div class="space-y-3">
								<span class="block text-xs font-semibold tracking-widest uppercase text-olive-500 dark:text-olive-400">Tags</span>
								<div class="flex flex-wrap gap-1.5">
									{tags.map((t) => (
										<a 
											href={`/tag/${t.slug}`} 
											class="inline-block px-2.5 py-0.5 text-xs text-olive-700 dark:text-olive-300 bg-olive-950/2.5 dark:bg-white/5 border border-olive-950/5 dark:border-white/5 rounded-full hover:text-olive-950 dark:hover:text-white hover:bg-olive-950/5 dark:hover:bg-white/10 transition-colors duration-150"
										>
											{t.label}
										</a>
									))}
								</div>
							</div>
						)
					}
				</div>
			</aside>

			{/* Center Column: Article Main */}
			<div class="lg:col-span-6 col-span-1 min-w-0">
				<header class="mb-10">
					{/* Mobile Meta (Visible only when desktop meta sidebar is hidden) */}
					<div class="lg:hidden flex items-center flex-wrap gap-x-2 gap-y-1 text-sm text-olive-600 dark:text-olive-400 mb-4">
						{
							bylines.length > 0 && (
								<>
									<span class="font-medium text-olive-700 dark:text-olive-300">
										{bylines.map((credit, i) => (
											<Fragment key={credit.byline.id}>
												{i > 0 && ", "}
												{credit.byline.displayName}
											</Fragment>
										))}
									</span>
									<span class="w-1 h-1 rounded-full bg-olive-300 dark:bg-olive-700" />
								</>
							)
						}
						{
							publishDate && (
								<>
									<time>{publishDate}</time>
									<span class="w-1 h-1 rounded-full bg-olive-300 dark:bg-olive-700" />
								</>
							)
						}
						<span>{readingTime} min read</span>
					</div>
					<h1 class="text-4xl sm:text-5xl font-display tracking-tight text-olive-950 dark:text-white mb-6 leading-tight" {...post.edit.title}>
						{post.data.title}
					</h1>
					{
						post.data.excerpt && (
							<p class="text-xl text-olive-700 dark:text-olive-400 leading-relaxed font-sans" {...post.edit.excerpt}>
								{post.data.excerpt}
							</p>
						)
					}
				</header>

				{/* Rich Text Body Content */}
				<div class="article-content font-sans">
					<PortableText value={post.data.content} components={{ type: blockComponents }} />
				</div>

				{/* Comments Area */}
				<div class="article-comments mt-16 pt-10 border-t border-olive-950/10 dark:border-white/10">
					<Comments collection="posts" contentId={post.data.id} threaded />
					<CommentForm collection="posts" contentId={post.data.id} />
				</div>
			</div>

			{/* Right Column: Table of Contents & Sidebar widgets */}
			<aside class="lg:col-span-3 lg:block hidden sticky top-28 self-start space-y-8">
				<nav class="toc border-b border-olive-950/10 dark:border-white/10 pb-6" aria-label="Table of contents">
					<h4 class="text-xs font-semibold tracking-widest uppercase text-olive-500 dark:text-olive-400 mb-3">On this page</h4>
					<div class="toc-content" id="toc-content">
						<!-- Populated by JS -->
					</div>
				</nav>
				<div class="sidebar-widgets">
					<WidgetArea name="sidebar" />
				</div>
			</aside>
		</div>
	</article>

	{/* Related Posts Section */}
	{
		otherPostsWithTags.length > 0 && (
			<section class="bg-olive-950/2.5 dark:bg-white/2.5 border-t border-b border-olive-950/5 dark:border-white/5 py-16 mt-16">
				<div class="mx-auto w-full max-w-7xl px-6 lg:px-10">
					<h2 class="text-2xl font-semibold tracking-tight text-olive-950 dark:text-white mb-10">Continue reading</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
						{otherPostsWithTags.map(
							({ post: p, tags: postTags, bylines: postBylines }) => (
								<PostCard
									title={p.data.title}
									excerpt={p.data.excerpt}
									featuredImage={p.data.featured_image}
									href={`/posts/${p.id}`}
									date={p.data.publishedAt ?? undefined}
									readingTime={getReadingTime(p.data.content)}
									tags={postTags.map((t) => ({ slug: t.slug, label: t.label }))}
									bylines={postBylines}
								/>
							)
						)}
					</div>
				</div>
			</section>
		)
	}

	<script>
		// Build table of contents from h2/h3 headings
		function buildToc() {
			const content = document.querySelector(".article-content");
			const tocContainer = document.getElementById("toc-content");
			if (!content || !tocContainer) return;

			const headings = content.querySelectorAll("h2, h3");
			if (headings.length === 0) {
				const toc = document.querySelector(".toc") as HTMLElement | null;
				if (toc) toc.style.display = "none";
				return;
			}

			const list = document.createElement("ul");
			list.className = "space-y-2 list-none p-0 m-0";

			headings.forEach((heading, index) => {
				if (!heading.id) {
					heading.id = `heading-${index}`;
				}

				const li = document.createElement("li");
				li.className = heading.tagName === "H3" ? "pl-3" : "";

				const link = document.createElement("a");
				link.href = `#${heading.id}`;
				link.className = "toc-link block text-sm text-olive-600 dark:text-olive-400 hover:text-olive-950 dark:hover:text-white transition-colors duration-150 py-0.5 leading-snug";
				link.textContent = heading.textContent;

				li.appendChild(link);
				list.appendChild(li);
			});

			tocContainer.appendChild(list);

			// Highlight current section on scroll
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						const id = entry.target.id;
						const link = tocContainer.querySelector(`a[href="#${id}"]`);
						if (link) {
							if (entry.isIntersecting) {
								tocContainer
									.querySelectorAll(".toc-link")
									.forEach((l) => l.classList.remove("text-olive-950", "dark:text-white", "font-medium"));
								link.classList.add("text-olive-950", "dark:text-white", "font-medium");
							}
						}
					});
				},
				{ rootMargin: "-80px 0px -80% 0px" }
			);

			headings.forEach((heading) => observer.observe(heading));
		}

		// Run buildToc on load
		buildToc();
	</script>

	<style>
		/* Custom style tag for styling PortableText content without @tailwindcss/typography */
		.article-content {
			font-size: 1.125rem;
			line-height: 1.8;
			color: var(--color-olive-800);
		}
		:global(.dark) .article-content {
			color: var(--color-olive-200);
		}
		.article-content :global(p) {
			margin-bottom: 1.5rem;
		}
		.article-content :global(h2) {
			font-family: var(--font-display);
			font-size: 2rem;
			font-weight: 600;
			line-height: 1.25;
			color: var(--color-olive-950);
			margin-top: 2.5rem;
			margin-bottom: 1rem;
			scroll-margin-top: 7rem;
		}
		:global(.dark) .article-content :global(h2) {
			color: #fff;
		}
		.article-content :global(h3) {
			font-family: var(--font-display);
			font-size: 1.5rem;
			font-weight: 600;
			line-height: 1.3;
			color: var(--color-olive-950);
			margin-top: 2rem;
			margin-bottom: 0.75rem;
			scroll-margin-top: 7rem;
		}
		:global(.dark) .article-content :global(h3) {
			color: #fff;
		}
		.article-content :global(blockquote) {
			margin: 2rem 0;
			padding: 1rem 1.5rem;
			border-left: 3px solid var(--color-olive-300);
			background: var(--color-olive-950)/2.5;
			border-radius: 0 1rem 1rem 0;
			color: var(--color-olive-900);
			font-style: italic;
		}
		:global(.dark) .article-content :global(blockquote) {
			border-left-color: var(--color-olive-700);
			background: white/5;
			color: var(--color-olive-100);
		}
		.article-content :global(pre) {
			margin: 2rem 0;
			padding: 1.25rem;
			background: var(--color-olive-950)/2.5;
			border: 1px solid var(--color-olive-950)/5;
			border-radius: 1rem;
			overflow-x: auto;
			font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
			font-size: 0.875rem;
			line-height: 1.6;
		}
		:global(.dark) .article-content :global(pre) {
			background: white/5;
			border-color: white/5;
		}
		.article-content :global(code) {
			font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
			font-size: 0.9em;
			background: var(--color-olive-950)/5;
			padding: 0.2rem 0.4rem;
			border-radius: 0.375rem;
			color: var(--color-olive-950);
		}
		:global(.dark) .article-content :global(code) {
			background: white/10;
			color: #fff;
		}
		.article-content :global(pre code) {
			background: none;
			padding: 0;
			color: inherit;
		}
		.article-content :global(ul) {
			list-style-type: disc;
			margin-bottom: 1.5rem;
			padding-left: 1.5rem;
		}
		.article-content :global(ol) {
			list-style-type: decimal;
			margin-bottom: 1.5rem;
			padding-left: 1.5rem;
		}
		.article-content :global(li) {
			margin-bottom: 0.5rem;
		}
		.article-content :global(img) {
			margin: 2.5rem 0;
			border-radius: 1rem;
			border: 1px solid var(--color-olive-950)/5;
		}
		:global(.dark) .article-content :global(img) {
			border-color: white/5;
		}
		.article-content :global(hr) {
			margin: 3rem 0;
			border: none;
			border-top: 1px solid var(--color-olive-950)/10;
		}
		:global(.dark) .article-content :global(hr) {
			border-top-color: white/10;
		}
		.article-content :global(a) {
			color: var(--color-olive-950);
			text-decoration: underline;
			text-underline-offset: 4px;
			text-decoration-thickness: 1px;
			font-weight: 500;
		}
		:global(.dark) .article-content :global(a) {
			color: #fff;
		}
		.article-content :global(a:hover) {
			text-decoration-thickness: 2px;
		}

		/* Styling Comments Component and Form Fields to blend with Oatmeal */
		.article-comments :global(.ec-comment-form-field input),
		.article-comments :global(.ec-comment-form-field textarea) {
			background: var(--color-olive-100) !important;
			border: 1px solid rgba(0, 0, 0, 0.08) !important;
			color: var(--color-olive-950) !important;
			border-radius: 0.75rem !important;
			padding: 0.75rem 1rem !important;
			font-family: var(--font-sans) !important;
		}
		:global(.dark) .article-comments :global(.ec-comment-form-field input),
		:global(.dark) .article-comments :global(.ec-comment-form-field textarea) {
			background: var(--color-olive-950) !important;
			border-color: rgba(255, 255, 255, 0.1) !important;
			color: #fff !important;
		}
		.article-comments :global(.ec-comment-user-info) {
			background: rgba(0, 0, 0, 0.02) !important;
			border: 1px solid rgba(0, 0, 0, 0.08) !important;
			border-radius: 0.75rem !important;
		}
		:global(.dark) .article-comments :global(.ec-comment-user-info) {
			background: rgba(255, 255, 255, 0.02) !important;
			border-color: rgba(255, 255, 255, 0.1) !important;
		}
		.article-comments :global(.ec-comment-form-submit) {
			background: var(--color-olive-900) !important;
			color: #white !important;
			border-radius: 9999px !important;
			font-weight: 500 !important;
			transition: background 150ms ease !important;
		}
		:global(.dark) .article-comments :global(.ec-comment-form-submit) {
			background: #fff !important;
			color: var(--color-olive-950) !important;
		}
		.article-comments :global(.ec-comment-form-submit:hover) {
			background: var(--color-olive-800) !important;
		}
		:global(.dark) .article-comments :global(.ec-comment-form-submit:hover) {
			background: var(--color-olive-100) !important;
		}
	</style>
</Base>
