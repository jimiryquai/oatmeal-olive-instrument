---
import Base from '../layouts/Base.astro'
import ButtonLink from '@jamesryan/ui/components/elements/ButtonLink.astro'
import PlainButtonLink from '@jamesryan/ui/components/elements/PlainButtonLink.astro'
import Main from '@jamesryan/ui/components/elements/main.astro'
import ChevronIcon from '@jamesryan/ui/components/icons/chevron-icon.astro'
import GitHubIcon from '@jamesryan/ui/components/icons/social/github-icon.astro'
import XIcon from '@jamesryan/ui/components/icons/social/x-icon.astro'
import YouTubeIcon from '@jamesryan/ui/components/icons/social/youtube-icon.astro'
import CallToActionSimpleCentered from '@jamesryan/ui/components/sections/CallToActionSimpleCentered.astro'
import FooterLink from '@jamesryan/ui/components/sections/FooterLink.astro'
import FooterWithLinksAndSocialIcons from '@jamesryan/ui/components/sections/FooterWithLinksAndSocialIcons.astro'
import SocialLink from '@jamesryan/ui/components/sections/SocialLink.astro'
import HeroSimpleCentered from '@jamesryan/ui/components/sections/HeroSimpleCentered.astro'
import NavbarLink from '@jamesryan/ui/components/sections/NavbarLink.astro'
import NavbarLogo from '@jamesryan/ui/components/sections/NavbarLogo.astro'
import NavbarWithLogoActionsAndLeftAlignedLinks from '@jamesryan/ui/components/sections/NavbarWithLogoActionsAndLeftAlignedLinks.astro'
import Stat from '@jamesryan/ui/components/sections/Stat.astro'
import StatsThreeColumnWithDescription from '@jamesryan/ui/components/sections/StatsThreeColumnWithDescription.astro'
import TeamFourColumnGrid from '@jamesryan/ui/components/sections/TeamFourColumnGrid.astro'
import TeamMember from '@jamesryan/ui/components/sections/TeamMember.astro'
import TestimonialLargeQuote from '@jamesryan/ui/components/sections/TestimonialLargeQuote.astro'
---

<Base hideHeaderFooter={true} title="About" description="We're on a mission to take the human element completely out of customer support.">
  <NavbarWithLogoActionsAndLeftAlignedLinks id="navbar">
    <NavbarLogo slot="logo" href="#">
      <img
        src="/img/logos/oatmeal-instrument-color-olive-950.svg"
        alt="Oatmeal"
        class="dark:hidden"
        width={85}
        height={28}
      />
      <img
        src="/img/logos/oatmeal-instrument-color-white.svg"
        alt="Oatmeal"
        class="not-dark:hidden"
        width={85}
        height={28}
      />
    </NavbarLogo>
    <Fragment slot="links">
      <NavbarLink href="#">Pricing</NavbarLink>
      <NavbarLink href="#">About</NavbarLink>
      <NavbarLink href="#">Docs</NavbarLink>
      <NavbarLink href="/_emdash/admin" class="sm:hidden">Log in</NavbarLink>
    </Fragment>
    <Fragment slot="actions">
      <PlainButtonLink href="/_emdash/admin" class="max-sm:hidden">Log in</PlainButtonLink>
      <ButtonLink href="#">Get started</ButtonLink>
    </Fragment>
  </NavbarWithLogoActionsAndLeftAlignedLinks>

  <Main>
    <!-- Hero -->
    <HeroSimpleCentered
      id="hero"
      headline="Your customer success is our mission."
    >
      <p slot="subheadline">
        Simplify your shared inbox, collaborate effortlessly, and give every customer a reply that feels personal,
        even if it was written by a bot.
      </p>
    </HeroSimpleCentered>

    <!-- Stats -->
    <StatsThreeColumnWithDescription
      id="stats"
      heading="About Oatmeal"
    >
      <Fragment slot="description">
        <p>
          Oatmeal was founded on the belief that customer support should be personal, fast, and most importantly,
          highly profitable.
        </p>
        <p>
          The problem with traditional AI customer support tools is that they often lack the human touch that
          customers crave. At Oatmeal, we combine the power of AI with a massive network of low wage workers
          stationed around the globe to deliver customer support that feels personal and authentic.
        </p>
        <p>
          Oatmeal's competitive advantage lies in the fact that we can undercut our competitors who rely on
          expensive hardware based compute. Our network of human based compute centers allows us to provide
          high-quality customer support at a fraction of the cost. Compared to data centers that consume massive
          amounts of electricity and water, our approach is both sustainable and cost effective.
        </p>
      </Fragment>
      <Stat stat="2M+" text="Emails manually processed every week across thousands of teams." />
      <Stat stat="99.98%" text="Uptime — because your customers never stop complaining." />
      <Stat stat="70+" text="Countries where we have low wage workers pretending to be AI." />
    </StatsThreeColumnWithDescription>

    <!-- Testimonial -->
    <TestimonialLargeQuote
      id="testimonial"
      name="Jordan Rogers"
      byline="Founder at Anomaly"
    >
      <p slot="quote">
        Oatmeal has completely transformed our customer support operations. The blend of AI efficiency and human
        empathy has allowed us to provide exceptional service while significantly reducing costs.
      </p>
      <img
        slot="img"
        src="/img/avatars/10-size-160.webp"
        alt=""
        class="not-dark:bg-white/75 dark:bg-black/75"
        width={160}
        height={160}
      />
    </TestimonialLargeQuote>

    <!-- Team -->
    <TeamFourColumnGrid
      id="team"
      headline="Our leadership team"
    >
      <p slot="subheadline">
        Oatmeals's leadership team combines decades of experience in private equity, where they honed their skills
        in cost-cutting and maximizing shareholder value.
      </p>
      <TeamMember
        name="Leslie Alexander"
        byline="Co-Founder / CEO"
      >
        <img
          slot="img"
          src="/img/avatars/1-h-1000-w-800.webp"
          alt=""
          class="not-dark:bg-white/75 dark:bg-black/75"
          width={800}
          height={1000}
        />
      </TeamMember>
      <TeamMember
        name="Michael Foster"
        byline="Co-Founder / CTO"
      >
        <img
          slot="img"
          src="/img/avatars/2-h-1000-w-800.webp"
          alt=""
          class="not-dark:bg-white/75 dark:bg-black/75"
          width={800}
          height={1000}
        />
      </TeamMember>
      <TeamMember
        name="Dries Vincent"
        byline="Business Relations"
      >
        <img
          slot="img"
          src="/img/avatars/7-h-1000-w-800.webp"
          alt=""
          class="not-dark:bg-white/75 dark:bg-black/75"
          width={800}
          height={1000}
        />
      </TeamMember>
      <TeamMember
        name="Lindsay Walton"
        byline="Front-end Developer"
      >
        <img
          slot="img"
          src="/img/avatars/4-h-1000-w-800.webp"
          alt=""
          class="not-dark:bg-white/75 dark:bg-black/75"
          width={800}
          height={1000}
        />
      </TeamMember>
      <TeamMember
        name="Noor Hasan"
        byline="Designer"
      >
        <img
          slot="img"
          src="/img/avatars/5-h-1000-w-800.webp"
          alt=""
          class="not-dark:bg-white/75 dark:bg-black/75"
          width={800}
          height={1000}
        />
      </TeamMember>
      <TeamMember
        name="Tom Cook"
        byline="Director of Product"
      >
        <img
          slot="img"
          src="/img/avatars/6-h-1000-w-800.webp"
          alt=""
          class="not-dark:bg-white/75 dark:bg-black/75"
          width={800}
          height={1000}
        />
      </TeamMember>
      <TeamMember
        name="Whitney Francis"
        byline="Copywriter"
      >
        <img
          slot="img"
          src="/img/avatars/8-h-1000-w-800.webp"
          alt=""
          class="not-dark:bg-white/75 dark:bg-black/75"
          width={800}
          height={1000}
        />
      </TeamMember>
      <TeamMember
        name="Leonard Wu"
        byline="Senior Designer"
      >
        <img
          slot="img"
          src="/img/avatars/3-h-1000-w-800.webp"
          alt=""
          class="not-dark:bg-white/75 dark:bg-black/75"
          width={800}
          height={1000}
        />
      </TeamMember>
    </TeamFourColumnGrid>

    <!-- Call To Action -->
    <CallToActionSimpleCentered
      id="call-to-action"
      headline="Have anymore questions?"
    >
      <p slot="subheadline">Chat to someone on our sales team, who will make promises about our roadmap that we won't keep.</p>
      <div slot="cta" class="flex items-center gap-4">
        <ButtonLink href="#" size="lg">
          Chat with us
        </ButtonLink>

        <PlainButtonLink href="#" size="lg">
          Book a demo <ChevronIcon />
        </PlainButtonLink>
      </div>
    </CallToActionSimpleCentered>
  </Main>

  <FooterWithLinksAndSocialIcons id="footer">
    <Fragment slot="links">
      <FooterLink href="#">About</FooterLink>
      <FooterLink href="#">Careers</FooterLink>
      <FooterLink href="#">Blog</FooterLink>
      <FooterLink href="#">Help Center</FooterLink>
      <FooterLink href="#">Press Kit</FooterLink>
      <FooterLink href="#">Privacy Policy</FooterLink>
    </Fragment>
    <Fragment slot="socialLinks">
      <SocialLink href="https://x.com" name="X">
        <XIcon />
      </SocialLink>
      <SocialLink href="https://github.com" name="GitHub">
        <GitHubIcon />
      </SocialLink>
      <SocialLink href="https://www.youtube.com" name="YouTube">
        <YouTubeIcon />
      </SocialLink>
    </Fragment>
    <span slot="fineprint">© 2025 Oatmeal, Inc.</span>
  </FooterWithLinksAndSocialIcons>
</Base>
