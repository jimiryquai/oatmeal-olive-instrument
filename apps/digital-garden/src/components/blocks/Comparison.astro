---
import PlanComparisonTable from "@jamesryan/ui/components/sections/PlanComparisonTable.astro";

interface RawItem {
	groupName: string;
	name: string;
	starterValue: string;
	growthValue: string;
	proValue: string;
}

interface Props {
	node: {
		_key?: string;
		items: RawItem[];
	};
}

const { node } = Astro.props;
const { _key, items = [] } = node;

function parseValue(val: string): string | boolean {
	const trimmed = (val || "").trim();
	if (trimmed === "true") return true;
	if (trimmed === "false") return false;
	return trimmed;
}

const groups: Array<{
	title: string;
	features: Array<{
		name: string;
		value: Record<string, string | boolean>;
	}>;
}> = [];

for (const item of items) {
	const groupTitle = item.groupName || "General";
	let group = groups.find((g) => g.title === groupTitle);
	if (!group) {
		group = { title: groupTitle, features: [] };
		groups.push(group);
	}

	group.features.push({
		name: item.name,
		value: {
			Starter: parseValue(item.starterValue),
			Growth: parseValue(item.growthValue),
			Pro: parseValue(item.proValue),
		},
	});
}

const plans = ["Starter", "Growth", "Pro"];
---

<PlanComparisonTable
	id={_key || "comparison"}
	plans={plans}
	features={groups}
/>
