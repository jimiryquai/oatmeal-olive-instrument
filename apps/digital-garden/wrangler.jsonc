{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "digital-garden",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-02-24",
	"compatibility_flags": ["nodejs_compat"],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "garden-db",
		},
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "garden-media",
		},
	],
	// Worker Loader for plugin sandboxing
	"worker_loaders": [
		{
			"binding": "LOADER",
		},
	],
}
