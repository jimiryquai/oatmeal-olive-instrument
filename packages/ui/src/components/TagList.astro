---
interface Props {
  tags: Array<{ slug: string; label: string }>;
  class?: string;
}

const { tags, class: className } = Astro.props;
---

{tags.length > 0 && (
  <ul class:list={["flex flex-wrap gap-2 list-none p-0 m-0", className]}>
    {tags.map((tag) => (
      <li>
        <a 
          href={`/tag/${tag.slug}`} 
          class="inline-block px-3 py-1 text-sm text-olive-700 dark:text-olive-300 bg-olive-950/2.5 dark:bg-white/5 border border-olive-950/5 dark:border-white/5 rounded-full hover:text-olive-950 dark:hover:text-white hover:bg-olive-950/5 dark:hover:bg-white/10 transition-colors duration-150"
        >
          {tag.label}
        </a>
      </li>
    ))}
  </ul>
)}
