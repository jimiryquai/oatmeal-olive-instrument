---
import { clsx } from 'clsx/lite'

interface Props {
  logo?: any
  text?: any
  footnote?: any
  class?: string
  [key: string]: any
}

const {
  logo,
  text,
  footnote,
  class: className,
  ...props
} = Astro.props
---
<div
  class={clsx('flex flex-col justify-between gap-6 rounded-xl bg-olive-950/2.5 p-6 dark:bg-white/5', className)}
  {...props}
>
  <div class="flex flex-col items-start gap-2">
    <div class="flex h-8 shrink-0">
      {logo}
      <slot name="logo" />
    </div>
    <p class="text-sm/7 text-olive-700 dark:text-olive-400">
      {text}
      <slot name="text" />
    </p>
  </div>
  <p class="text-xs/6 text-olive-700 dark:text-olive-400">
    {footnote}
    <slot name="footnote" />
  </p>
</div>
