---
import { clsx } from 'clsx/lite'
import Container from '../elements/container.astro'

interface Props {
  class?: string
  [key: string]: any
}

const { class: className, ...props } = Astro.props
---
<footer class={clsx('pt-16', className)} {...props}>
  <div class="bg-olive-950/2.5 py-16 text-olive-950 dark:bg-white/5 dark:text-white">
    <Container class="flex flex-col gap-16">
      <div class="grid grid-cols-1 gap-x-6 gap-y-16 text-sm/7 lg:grid-cols-2">
        <slot name="cta" />
        <nav class="grid grid-cols-2 gap-6 sm:has-[>:last-child:nth-child(3)]:grid-cols-3 sm:has-[>:nth-child(5)]:grid-cols-3 md:has-[>:last-child:nth-child(4)]:grid-cols-4 lg:max-xl:has-[>:last-child:nth-child(4)]:grid-cols-2">
          <slot name="links" />
        </nav>
      </div>
      <div class="flex items-center justify-between gap-10 text-sm/7">
        <div class="text-olive-600 dark:text-olive-500">
          <slot name="fineprint" />
        </div>
        {Astro.slots.has('socialLinks') && (
          <div class="flex items-center gap-4 sm:gap-10">
            <slot name="socialLinks" />
          </div>
        )}
      </div>
    </Container>
  </div>
</footer>
